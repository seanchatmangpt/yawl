{
  "id": "jtbd4-customer-support",
  "name": "Customer Support Workflow",
  "description": "Customer support workflow with exception handling, retry mechanisms, and multi-channel support",
  "complexity": "Medium",
  "source": "E-commerce Customer Service Adaptation",
  "business_area": "Customer Service",
  "process_flow": "Ticket Creation → Triage → Resolution → Follow-up → Closure",
  "key_features": [
    "Multi-channel support (phone, email, chat, social)",
    "Exception handling with escalation paths",
    "Retry mechanisms for failed attempts",
    "Service level agreements (SLAs)",
    "Knowledge base integration",
    "Customer satisfaction tracking"
  ],
  "channel_types": {
    "digital_channels": ["email", "chat", "social_media"],
    "voice_channels": ["phone", "video_call"],
    "self_service": ["knowledge_base", "faq", "community"]
  },
  "sla_policies": {
    "critical": "1 hour response, 4 hour resolution",
    "high": "2 hour response, 8 hour resolution",
    "normal": "4 hour response, 24 hour resolution",
    "low": "8 hour response, 72 hour resolution"
  },
  "exception_types": {
    "technical": ["system_failure", "integration_error", "bug"],
    "process": ["missing_info", "wrong_channel", "miscommunication"],
    "resource": ["agent_unavailable", "escalation_required", "specialist_needed"],
    "customer": ["escalation_request", "complaint", "abuse"]
  },
  "retry_policies": {
    "max_attempts": 3,
    "backoff_strategy": "exponential",
    "success_conditions": ["issue_resolved", "customer_satisfied"],
    "failure_conditions": ["same_error", "customer_rejects_solution", "timeout"]
  },
  "entities": {
    "cases": {
      "support_ticket": "Customer issue being handled",
      "customer_profile": "Customer information and history",
      "resolution_attempt": "Previous resolution efforts"
    },
    "events": [
      "CreateTicket",
      "TriageTicket",
      "AssignAgent",
      "AttemptResolution",
      "EscalateTicket",
      "RetryResolution",
      "FollowUpRequired",
      "CloseTicket",
      "ReopenTicket"
    ],
    "resources": {
      "level1_agent": "Basic issue resolution",
      "level2_agent": "Complex technical issues",
      "level3_specialist": "Expert level problems",
      "knowledge_base": "Self-service resources"
    }
  }
}