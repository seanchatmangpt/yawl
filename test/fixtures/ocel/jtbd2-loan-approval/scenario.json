{
  "id": "jtbd2-loan-approval",
  "name": "Loan Approval Workflow",
  "description": "Complex loan approval workflow with multi-level routing, parallel processing, and conditional logic",
  "complexity": "Medium",
  "source": "BPI Challenge 2019 - Loan Application",
  "business_area": "Financial Services",
  "process_flow": "Application → Initial Assessment → Risk Analysis → Approval → Funding",
  "key_features": [
    "Multi-level approval hierarchy",
    "Parallel subprocesses for risk analysis",
    "Conditional routing based on loan amount",
    "Resource assignment based on expertise",
    "Automatic/manual decision paths",
    "Exception handling for incomplete applications"
  ],
  "routing_rules": {
    "amount_thresholds": {
      "small_loan": "< 10,000",
      "medium_loan": "10,000 - 50,000",
      "large_loan": "> 50,000"
    },
    "approval_required": {
      "small": "officer",
      "medium": "supervisor",
      "large": "committee"
    }
  },
  "entities": {
    "cases": {
      "loan_application": "Loan being processed",
      "customer": "Applicant",
      "collateral": "Loan collateral items"
    },
    "events": [
      "SubmitApplication",
      "InitialAssessment",
      "RiskAnalysis",
      "CreditCheck",
      "CollateralEvaluation",
      "DecisionReview",
      "ApproveLoan",
      "RejectApplication",
      "FundLoan"
    ],
    "resources": {
      "loan_officer": "Handles initial assessment",
      "risk_analyst": "Performs risk analysis",
      "credit_checker": "Runs credit checks",
      "collateral_specialist": "Evaluates collateral",
      "approval_manager": "Reviews decisions",
      "loan_committee": "Large loan approvals"
    }
  }
}