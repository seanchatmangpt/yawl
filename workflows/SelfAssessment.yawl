<?xml version="1.0" encoding="UTF-8"?>
<!--
  SelfAssessment.yawl — Meta-Assessment Workflow
  Self-Play Simulation Loop v3.0

  PURPOSE: The simulation evaluates its own performance using process mining
  to identify capability gaps and optimization opportunities.

  WORKFLOW STEPS:
  1. LoadHistory - Load simulation history (OCEL files from previous runs)
  2. DiscoverDFG - Discover DFG using ProcessMiningL3.discoverDfg
  3. CheckConformance - Check conformance against reference model
  4. IdentifyGaps - Identify capability gaps
  5. RankByWSJF - Rank gaps by WSJF
  6. GenerateProposals - Generate improvement proposals
  7. ExportOCEL2 - Export assessment results as OCEL2

  BRIDGE CALLS:
  - processMiningBridge.discoverDfg(ocelJson) → dfgJson
  - gapAnalysisEngine.discoverGaps(ocelJson, referenceModel) → gaps
  - gapAnalysisEngine.rankByWSJF(gaps) → prioritizedGaps
  - ocel2Exporter.exportEvents(events) → ocel2Json
-->
<specification xmlns="http://yawlfoundation.org/yawl/specification/3.0"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://yawlfoundation.org/yawl/specification/3.0
                                   http://yawlfoundation.org/yawl/schemas/YAWL_Specification3.0.xsd">

  <metaData>
    <title>Self-Assessment Workflow</title>
    <creator>YAWL Self-Play Loop v3.0</creator>
    <version>2.0.0</version>
    <description>
      Meta-assessment workflow where the simulation evaluates its own
      performance. Uses process mining to identify capability gaps and
      generates WSJF-ranked improvement proposals. This is a meta-workflow
      where the simulation evaluates itself using OCEL event logs.
    </description>
    <persistent>false</persistent>
    <identifier>SelfAssessment_2.0.0</identifier>
  </metaData>

  <schema xmlns="http://www.yawlfoundation.org/yawl/specification/3.0">
    <type definition="string" name="simulationId"/>
    <type definition="string" name="ocelLogPath"/>
    <type definition="string" name="ocelJson"/>
    <type definition="string" name="dfgJson"/>
    <type definition="double" name="fitness"/>
    <type definition="double" name="precision"/>
    <type definition="string" name="gaps"/>
    <type definition="string" name="prioritizedGaps"/>
    <type definition="string" name="proposals"/>
    <type definition="string" name="ocel2Json"/>
    <type definition="string" name="receiptHash"/>
  </schema>

  <decomposition id="SelfAssessment" isRootNet="true">
    <processControlElements>
      <inputCondition id="Start"/>

      <task id="LoadHistory">
        <description>Load simulation history (OCEL files from previous runs)</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="simulationId" type="string"/>
        <outputVar type="string" name="ocelLogPath"/>
        <outputVar type="string" name="ocelJson"/>
        <extension code="LoadOCELFiles">
          <parameter name="baseDir">simulation/history/</parameter>
          <parameter name="filePattern">*.ocel.json</parameter>
          <parameter name="maxFiles">50</parameter>
        </extension>
      </task>

      <task id="DiscoverDFG">
        <description>Discover DFG using ProcessMiningL3.discoverDfg</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="ocelJson" type="string"/>
        <outputVar type="string" name="dfgJson"/>
        <extension code="ProcessMining">
          <parameter name="bridge">ProcessMiningL3.discoverDfg</parameter>
          <parameter name="inputFormat">OCEL2</parameter>
        </extension>
      </task>

      <task id="CheckConformance">
        <description>Check conformance against reference model</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="ocelJson" type="string"/>
        <inputVar query="dfgJson" type="string"/>
        <outputVar type="double" name="fitness"/>
        <outputVar type="double" name="precision"/>
        <extension code="ConformanceCheck">
          <parameter name="bridge">ProcessMiningL3.checkConformance</parameter>
          <parameter name="referenceModel">self_assessment_reference.pnml</parameter>
        </extension>
      </task>

      <task id="IdentifyGaps">
        <description>Identify capability gaps from simulation traces</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="ocelJson" type="string"/>
        <inputVar query="fitness" type="double"/>
        <inputVar query="precision" type="double"/>
        <outputVar type="string" name="gaps"/>
        <extension code="GapDiscovery">
          <parameter name="bridge">GapAnalysisEngine.discoverGaps</parameter>
          <parameter name="referenceModel">capability-registry.json</parameter>
          <parameter name="threshold">0.85</parameter>
        </extension>
      </task>

      <task id="RankByWSJF">
        <description>Rank discovered gaps by WSJF score</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="gaps" type="string"/>
        <outputVar type="string" name="prioritizedGaps"/>
        <extension code="WSJFRanking">
          <parameter name="bridge">GapAnalysisEngine.rankByWSJF</parameter>
          <parameter name="weights">businessValue=1.0,timeCriticality=0.8,riskReduction=0.6</parameter>
        </extension>
      </task>

      <task id="GenerateProposals">
        <description>Generate improvement proposals from prioritized gaps</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="prioritizedGaps" type="string"/>
        <inputVar query="fitness" type="double"/>
        <outputVar type="string" name="proposals"/>
        <extension code="ProposalGeneration">
          <parameter name="agent">V7DesignAgent</parameter>
          <parameter name="maxProposals">5</parameter>
          <parameter name="format">YAWLWorkflow</parameter>
        </extension>
      </task>

      <task id="ExportOCEL2">
        <description>Export assessment results as OCEL2</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="proposals" type="string"/>
        <inputVar query="ocelJson" type="string"/>
        <inputVar query="fitness" type="double"/>
        <outputVar type="string" name="ocel2Json"/>
        <extension code="OCEL2Export">
          <parameter name="bridge">Ocel2Exporter.exportEvents</parameter>
          <parameter name="includeAssessmentData">true</parameter>
        </extension>
      </task>

      <task id="ReceiptChainUpdate">
        <description>Record assessment results in Blake3 receipt chain</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="ocel2Json" type="string"/>
        <inputVar query="fitness" type="double"/>
        <outputVar type="string" name="receiptHash"/>
        <extension code="Blake3Receipt">
          <parameter name="algorithm">BLAKE3</parameter>
          <parameter name="metadata">assessment_type=self_play_evaluation</parameter>
        </extension>
      </task>

      <task id="MetaAnalysis">
        <description>Perform meta-analysis on assessment results</description>
        <inputGate><split code="XOR">true</split></inputGate>
        <outputGate><join code="XOR">true</join></outputGate>
        <inputVar query="proposals" type="string"/>
        <inputVar query="fitness" type="double"/>
        <inputVar query="ocel2Json" type="string"/>
        <outputVar type="string" name="metaAnalysis"/>
        <extension code="MetaAnalysis">
          <parameter name="analysisType">convergence_trend</parameter>
          <parameter name="lookbackPeriod">7</parameter>
        </extension>
      </task>

      <outputCondition id="End"/>

      <flowsInto>
        <source>Start</source>
        <destination>LoadHistory</destination>
      </flowsInto>
      <flowsInto>
        <source>LoadHistory</source>
        <destination>DiscoverDFG</destination>
      </flowsInto>
      <flowsInto>
        <source>DiscoverDFG</source>
        <destination>CheckConformance</destination>
      </flowsInto>
      <flowsInto>
        <source>CheckConformance</source>
        <destination>IdentifyGaps</destination>
        <predicate>fitness &lt; 0.85 || precision &lt; 0.85</predicate>
      </flowsInto>
      <flowsInto>
        <source>CheckConformance</source>
        <destination>ExportOCEL2</destination>
        <predicate>fitness >= 0.85 &amp;&amp; precision >= 0.85</predicate>
      </flowsInto>
      <flowsInto>
        <source>IdentifyGaps</source>
        <destination>RankByWSJF</destination>
      </flowsInto>
      <flowsInto>
        <source>RankByWSJF</source>
        <destination>GenerateProposals</destination>
      </flowsInto>
      <flowsInto>
        <source>GenerateProposals</source>
        <destination>ExportOCEL2</destination>
      </flowsInto>
      <flowsInto>
        <source>ExportOCEL2</source>
        <destination>MetaAnalysis</destination>
      </flowsInto>
      <flowsInto>
        <source>MetaAnalysis</source>
        <destination>ReceiptChainUpdate</destination>
      </flowsInto>
      <flowsInto>
        <source>ReceiptChainUpdate</source>
        <destination>End</destination>
      </flowsInto>
    </processControlElements>
  </decomposition>
</specification>
