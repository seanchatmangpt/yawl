# =============================================================================
# BRIDGE CAPABILITIES (55)
# Groups: IMPORT(14) EXPORT(14) VALIDATE(12) CONVERT(5) INFER(6) MAP(4)
# =============================================================================

# --- IMPORT ---

dm:Cap_IMPORT_ODCS_SCHEMA
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_ODCS_SCHEMA" ;
    yawl-bridge:capabilityDescription "Import ODCS (Open Data Contract Standard) schema into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_odcs_schema" .

dm:Cap_IMPORT_ODPS_SCHEMA
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_ODPS_SCHEMA" ;
    yawl-bridge:capabilityDescription "Import ODPS (Open Data Product Standard) schema into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_odps_schema" .

dm:Cap_IMPORT_CADS_SCHEMA
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_CADS_SCHEMA" ;
    yawl-bridge:capabilityDescription "Import CADS (Canonical Abstract Data Schema) schema into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_cads_schema" .

dm:Cap_IMPORT_OPENAPI_SCHEMA
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_OPENAPI_SCHEMA" ;
    yawl-bridge:capabilityDescription "Import OpenAPI schema definition into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_openapi_schema" .

dm:Cap_IMPORT_BPMN_PROCESS
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_BPMN_PROCESS" ;
    yawl-bridge:capabilityDescription "Import BPMN 2.0 process definition into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_bpmn_process" .

dm:Cap_IMPORT_DMN_DECISION
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_DMN_DECISION" ;
    yawl-bridge:capabilityDescription "Import DMN (Decision Model and Notation) decision table into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_dmn_decision" .

dm:Cap_IMPORT_DECISION_RECORD
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_DECISION_RECORD" ;
    yawl-bridge:capabilityDescription "Import MADR (Markdown Architectural Decision Record) into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_decision_record" .

dm:Cap_IMPORT_KNOWLEDGE_BASE
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_KNOWLEDGE_BASE" ;
    yawl-bridge:capabilityDescription "Import knowledge base entries into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_knowledge_base" .

dm:Cap_IMPORT_SKETCH
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_SKETCH" ;
    yawl-bridge:capabilityDescription "Import a domain sketch or concept diagram into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_sketch" .

dm:Cap_IMPORT_DOMAIN_ORG
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_DOMAIN_ORG" ;
    yawl-bridge:capabilityDescription "Import domain organisation structure into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_domain_org" .

dm:Cap_IMPORT_TEMPLATE
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_TEMPLATE" ;
    yawl-bridge:capabilityDescription "Import a data model template into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_template" .

dm:Cap_IMPORT_CONFIGURATION
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_CONFIGURATION" ;
    yawl-bridge:capabilityDescription "Import SDK configuration settings into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_configuration" .

dm:Cap_IMPORT_VOCABULARY
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_VOCABULARY" ;
    yawl-bridge:capabilityDescription "Import domain vocabulary definitions into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_vocabulary" .

dm:Cap_IMPORT_CONSTRAINT_SET
    a yawl-bridge:BridgeCapability ;
    yawl-bridge:capabilityName        "IMPORT_CONSTRAINT_SET" ;
    yawl-bridge:capabilityDescription "Import a set of data validation constraints into the repository" ;
    yawl-bridge:nativeTarget          "dm_import_constraint_set" .

