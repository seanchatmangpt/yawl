<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.yawlfoundation</groupId>
        <artifactId>yawl-parent</artifactId>
        <version>6.0.0-GA</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>yawl-data-modelling</artifactId>
    <packaging>jar</packaging>
    <name>YAWL Data Modelling — Native Panama FFM Bridge</name>
    <description>
        Native Java 25 Panama FFM bridge over the data-modelling-sdk Rust crate (v2.3.0).
        Exposes 67 schema operations — ODCS/ODPS/CADS/OpenAPI/BPMN/DMN import-export,
        decision records (MADR), knowledge base (KB), sketches, domain organisation,
        and validation — via a generated L2/L3 bridge (WCP-NB-03/WCP-NB-04).

        The Rust cdylib (libdata_modelling_ffi.so) is compiled during generate-sources
        via cargo build. All computation delegates to the Rust SDK through a single
        dm_call dispatcher; no WASM or GraalVM runtime required.

        SDK source: github.com/OffeneDatenmodellierung/data-modelling-sdk v2.3.0 (MIT)
        Pattern: native-bridge-dm.ttl → ggen → DataModellingL2/L3.java
    </description>

    <dependencies>
        <!-- Jackson for JSON serialization in sync/pipeline layers -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jspecify</groupId>
            <artifactId>jspecify</artifactId>
        </dependency>
        <!-- Testing -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.hamcrest</groupId>
            <artifactId>hamcrest-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>../src</sourceDirectory>
        <testSourceDirectory>../test</testSourceDirectory>

        <resources>
            <resource>
                <directory>src/main/resources</directory>
            </resource>
        </resources>

        <plugins>
            <!-- Compile Rust cdylib during generate-sources -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>build-rust-ffi</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>cargo</executable>
                            <arguments>
                                <argument>build</argument>
                                <argument>--release</argument>
                                <argument>--manifest-path</argument>
                                <argument>${project.basedir}/../rust/data-modelling-ffi/Cargo.toml</argument>
                            </arguments>
                            <skip>${skipRustBuild}</skip>
                        </configuration>
                    </execution>
                    <!-- Copy the compiled native library into classpath resources for JAR bundling -->
                    <execution>
                        <id>copy-native-lib</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>bash</executable>
                            <arguments>
                                <argument>-c</argument>
                                <argument>OS=$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/darwin/'); ARCH=$(uname -m | sed 's/arm64/aarch64/'); if [ "$OS" = "darwin" ]; then LIB="libdata_modelling_ffi.dylib"; else LIB="libdata_modelling_ffi.so"; fi; DEST="src/main/resources/native/${OS}-${ARCH}"; mkdir -p "${DEST}"; cp "../rust/data-modelling-ffi/target/release/${LIB}" "${DEST}/${LIB}"</argument>
                            </arguments>
                            <skip>${skipRustBuild}</skip>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                        <!-- Panama FFM: enable-native-access required for SymbolLookup -->
                        <arg>-J--enable-native-access=ALL-UNNAMED</arg>
                    </compilerArgs>
                    <includes>
                        <include>**/org/yawlfoundation/yawl/datamodelling/**</include>
                    </includes>
                    <excludes>
                        <!-- Exclude src/test/java tree from main compilation -->
                        <exclude>test/java/**</exclude>
                    </excludes>
                    <testIncludes>
                        <testInclude>**/org/yawlfoundation/yawl/datamodelling/**</testInclude>
                    </testIncludes>
                </configuration>
                <executions>
                    <execution>
                        <id>default-testCompile</id>
                        <configuration>
                            <compilerArgs>
                                <arg>--enable-preview</arg>
                            </compilerArgs>
                            <testIncludes>
                                <testInclude>**/org/yawlfoundation/yawl/datamodelling/**</testInclude>
                            </testIncludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>**/org/yawlfoundation/yawl/datamodelling/**Test.java</include>
                    </includes>
                    <argLine>--enable-preview --enable-native-access=ALL-UNNAMED</argLine>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

    <properties>
        <!-- Set to true to skip Rust cargo build (e.g. in CI without cargo) -->
        <skipRustBuild>false</skipRustBuild>
    </properties>
</project>
