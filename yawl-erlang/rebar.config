{erl_opts, [
    debug_info,
    warnings_as_errors,
    {i, "include"}
]}.

{deps, []}.

{profiles, [
    {prod, [
        {erl_opts, [no_debug_info, warnings_as_errors]}
    ]},
    {test, [
        {erl_opts, [debug_info]},
        {deps, []}
    ]}
]}.

%% Application release configuration
{relx, [
    {release, {yawl, "6.0.0"}, [yawl, sasl]},
    {dev_mode, false},
    {include_erts, false},
    {extended_start_script, true}
]}.
