<?xml version="1.0" encoding="UTF-8"?>
<yawl:YAWLSpecification xmlns:yawl="http://www.yawlfoundation.org/yawl">
    <specificationID>SampleWorkflow</specificationID>
    <specificationVersion>2.0</specificationVersion>
    <YAWLNet>
        <netID>SampleNet</netID>
        <inputCondition>
            <conditionID>start</conditionID>
        </inputCondition>
        <outputCondition>
            <conditionID>end</conditionID>
        </outputCondition>
        <tasks>
            <taskID>task1</taskID>
            <taskID>task2</taskID>
        </tasks>
        <gateways>
            <gatewayID>gateway1</gatewayID>
        </gateways>
        <flows>
            <inputFlow>
                <flowID>flow1</flowID>
                <source>start</source>
                <target>task1</target>
            </inputFlow>
            <outputFlow>
                <flowID>flow2</flowID>
                <source>task1</source>
                <target>gateway1</target>
            </outputFlow>
            <inputFlow>
                <flowID>flow3</flowID>
                <source>gateway1</source>
                <target>task2</target>
            </inputFlow>
            <outputFlow>
                <flowID>flow4</flowID>
                <source>task2</source>
                <target>end</target>
            </outputFlow>
        </flows>
    </YAWLNet>
</yawl:YAWLSpecification>