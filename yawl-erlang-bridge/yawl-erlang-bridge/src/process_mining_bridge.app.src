{application, process_mining_bridge, [
    {description, "YAWL Process Mining Bridge"},
    {vsn, "1.1.0"},
    {registered, [
        process_mining_bridge,
        data_modelling_bridge,
        mnesia_registry,
        yawl_bridge_sup,
        yawl_bridge_telemetry,
        yawl_bridge_health_v2,
        yawl_bridge_mnesia_backup,
        yawl_bridge_nif_guard
    ]},
    {mod, {process_mining_bridge_app, []}},
    {applications, [
        kernel,
        stdlib,
        mnesia,
        lager,
        telemetry
    ]},
    {env, [
        {log_level, info},
        {backup_interval, 300000},
        {health_check_interval, 30000},
        {backup_dir, "/tmp/yawl_mnesia_backups"},
        {supervisor_intensity, 5},
        {supervisor_period, 60},
        {nif_timeout, 1000},
        {dirty_nif_timeout, 5000},
        {queue_limit, 1000},
        {queue_strategy, drop_oldest}
    ]}
]}.
