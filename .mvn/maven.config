# YAWL v6.0.0-GA - Maven 4 ONLY Configuration
#
# CRITICAL: This project uses Maven 4.0.0+ ONLY. No backward compatibility with Maven 3.x.
# This follows Toyota production system principles: strict standards, no workarounds.
#
# Requirements:
# 1. Maven 4.0.0+ must be available (check mvn --version)
# 2. mvnd (Maven Daemon) MUST be running before any build
# 3. Tree-based concurrent lifecycle enabled
# 4. 16 parallel artifact resolution threads (optimized for 16 cores)
# 5. Atomic deployment (deployAtEnd)
#
# Enforcement: See scripts/mvnd-enforce.sh for mvnd requirement validation.

# Maven 4.0.0+ ONLY: Tree-based lifecycle for optimal DAG-parallel builds
# Enables modules to start compilation as soon as dependencies reach 'ready' phase
# Note: May not work in all Maven 4 RC versions. If build fails, comment this out.
-b concurrent

# Parallel builds: 1.5 threads per CPU core (optimal for 16 cores = 24 threads)
-T 1.5C

# Batch mode (non-interactive)
-B

# Parallel artifact resolution (16 threads for parallel downloads)
-Dmaven.artifact.threads=16

# Maven 4: Consumer POM flattening for faster resolution
-Dmaven.consumer.pom.flatten=true

# Maven 4: Deploy all modules at end (atomic deployment)
-DdeployAtEnd=true

# Skip native builds by default (Rust NIF, Cargo, etc.)
# Re-enable with: -DskipNifBuild=false -DskipRustBuild=false
-DskipNifBuild=true
-DskipRustBuild=true

# Build cache - enables incremental builds
# Note: Disabled for Maven 4 RC. Re-enable with Maven 3.9.x for 50-80% speedup
-Dmaven.build.cache.enabled=false

# Java 25 preview features
-Dmaven.compiler.enable-preview=true

# JUnit 5 parallel execution (Optimized for virtual threads)
-Djunit.jupiter.execution.parallel.enabled=true
-Djunit.jupiter.execution.parallel.config.strategy=dynamic
-Djunit.jupiter.execution.parallel.config.dynamic.max-pool-size=512
-Djunit.jupiter.execution.parallel.config.dynamic.factor=4.0
-Djunit.jupiter.execution.parallel.config.default=concurrent
-Dsurefire.fail-if-no-specified-tests=false

# Surefire settings
-Dsurefire.forkCount=1.5C
-Dfailsafe.forkCount=1
-Dfailsafe.reuseForks=true

# Coverage collection
-Djacoco.skip=false
-Djacoco.output.dir=./target/coverage-reports
-Djacoco.output.format=xml
