  "validation_rules": [
    {
      "rule": "parallel_execution",
      "description": "Risk analysis, credit check, and collateral evaluation should run in parallel",
      "check": "SELECT AVG(MAX(timestamp) - MIN(timestamp)) FROM events WHERE activity IN ('RiskAnalysis', 'CreditCheck', 'CollateralEvaluation') AND case = ?",
      "expected_range": "4-6 hours"
    },
    {
      "rule": "conditional_routing",
      "description": "Loans > 50k should go to committee, <= 50k to supervisor/officer",
      "check": "SELECT COUNT(*) FROM events e JOIN attributes a ON e.id = a.event_id WHERE e.activity = 'ConditionalRouting' AND a.loan_amount <= 50000 AND a.requires_committee = false",
      "expected_min": 60
    },
    {
      "rule": "approval_hierarchy",
      "description": "Proper approval hierarchy followed based on loan amount",
      "check": "SELECT COUNT(*) FROM events WHERE activity = 'ApprovalDecision' AND approval_type IN ('officer', 'supervisor', 'committee')",
