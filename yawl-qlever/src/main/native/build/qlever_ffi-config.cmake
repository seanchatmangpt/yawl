# QLever FFI package configuration
# Generated by CMake from qlever_ffi-config.cmake.in



include(CMakeFindDependencyMacro)

# Dependencies
find_dependency(JDK)
@if(GTest_FOUND)
find_dependency(GTest REQUIRED)


# Provide targets
include("${CMAKE_CURRENT_LIST_DIR}/qlever_ffiTargets.cmake")

# Version information
set(QLever_FFI_VERSION 1.0.0)

# Helper functions
macro(find_qlever_ffi)
    if(NOT TARGET QLever::qlever_ffi)
        find_package(QLever REQUIRED)
    endif()
endmacro()

# Get library information function
function(get_qlever_ffi_info VAR)
    set(${VAR}
        "Qlever FFI Version: ${QLever_FFI_VERSION}"
        "Library: qlever_ffi"
        "Type: Shared Library"
        PARENT_SCOPE)
endfunction()
