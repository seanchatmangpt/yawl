        Objects.requireNonNull(type, "Type cannot be null");
        Objects.requireNonNull(encoder, "Encoder cannot be null");

        ENCODERS.put(type, encoder);
        TYPE_REGISTRY.put(type.getSimpleName(), type);
    }

    /**
     * Register custom decoder for Java type
     *
     * @param type Java type class
     * @param decoder Decoder implementation
     */
    public static synchronized <T> void registerDecoder(Class<T> type, Decoder<T> decoder) {
        Objects.requireNonNull(type, "Type cannot be null");
        Objects.requireNonNull(decoder, "Decoder cannot be null");

        DECODERS.put(type, decoder);
        TYPE_REGISTRY.put(type.getSimpleName(), type);
    }

    /**
