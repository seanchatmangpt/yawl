 * Generated from pm-bridge.ttl capabilities with automatic mapping validation.
 */
public final class ErlTermCodec {

    private static final Map<Class<?>, Encoder<?>> ENCODERS = new ConcurrentHashMap<>();
    private static final Map<Class<?>, Decoder<?>> DECODERS = new ConcurrentHashMap<>();
    private static final Map<String, Class<?>> TYPE_REGISTRY = new ConcurrentHashMap<>();

