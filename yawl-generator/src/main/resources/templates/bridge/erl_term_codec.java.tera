        Map<String, Class<?>> constraints = getCapabilityConstraints(capability);

        if (constraints.isEmpty()) {
            throw new ErlTermCodecException(
                "No constraints defined for capability: " + capability
            );
        }

        // Validate input against constraints
        ErlangTermValidator.validateAgainstSchema(input, constraints);
    }

