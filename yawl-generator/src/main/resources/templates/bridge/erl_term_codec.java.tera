            super(message, cause);
        }
    }

    // =============================================================================
    // Bridge Capability Mappings
    // =============================================================================

    private static class BridgeCapabilityMappings {
        private static final Map<String, Map<String, Class<?>>> CONSTRAINTS = new ConcurrentHashMap<>();

        static {
            // Initialize process mining bridge constraints
            Map<String, Class<?>> parseConstraints = new HashMap<>();
            parseConstraints.put("ocel2Json", String.class);
            parseConstraints.put("handle", ByteBuffer.class);
            CONSTRAINTS.put("parseOcel2Json", parseConstraints);

            Map<String, Class<?>> logConstraints = new HashMap<>();
            logConstraints.put("handle", ByteBuffer.class);
            logConstraints.put("result", Long.class);
            CONSTRAINTS.put("logEventCount", logConstraints);

            // Add more constraints as needed
        }

        static Map<String, Class<?>> getCapabilityConstraints(String capability) {
            return CONSTRAINTS.getOrDefault(capability, Collections.emptyMap());
        }
    }

    // =============================================================================
    // Validation Classes
    // =============================================================================

    private static class ErlangTermValidator {
        static boolean validateTerm(byte[] bytes) {
            // Validate Erlang term format
            if (bytes == null || bytes.length < 4) {
                return false;
            }

            // Check magic byte
            if (bytes[0] != 0x83) {
                return false;
            }

            // Check version
            if (bytes[1] != 0x69) {
                return false;
            }

            // Validate term structure recursively
            return validateTermStructure(bytes, 2);
        }

        private static boolean validateTermStructure(byte[] bytes, int position) {
            if (position >= bytes.length) {
                return false;
            }

            byte typeMarker = bytes[position];

            switch (typeMarker) {
                case 0x83: // Small integer
                    return position + 1 < bytes.length;
                case 0x69: // Integer
                    return position + 4 < bytes.length;
                case 0x6A: // Long
                    return position + 8 < bytes.length;
                case 0x6B: // Float
                    return position + 8 < bytes.length;
                case 0x70: // Boolean
                    return position + 1 < bytes.length;
                case 0x6C: // String
                    if (position + 2 >= bytes.length) {
                        return false;
                    }
                    int length = ByteBuffer.wrap(bytes, position + 2, 2).getShort();
                    return position + 2 + length <= bytes.length;
                default:
                    return false;
            }
        }

        static boolean validateObject(Object object, Class<?> expectedType) {
            Objects.requireNonNull(object, "Object cannot be null");
            Objects.requireNonNull(expectedType, "Expected type cannot be null");

            // Check type compatibility
            if (!expectedType.isAssignableFrom(object.getClass())) {
                return false;
            }

            // Type-specific validation
            if (expectedType == String.class) {
                String str = (String) object;
                return !str.isEmpty() && str.length() <= 65535; // Erlang string limit
            } else if (expectedType == Integer.class || expectedType == Long.class) {
                Number num = (Number) object;
                return num.longValue() >= Long.MIN_VALUE && num.longValue() <= Long.MAX_VALUE;
            } else if (expectedType == Double.class) {
                Number num = (Number) object;
                return !Double.isNaN(num.doubleValue());
            } else if (expectedType == Boolean.class) {
                return true; // Boolean is always valid
            } else if (expectedType == List.class) {
                List<?> list = (List<?>) object;
                return list != null && list.size() <= 1024; // Reasonable size limit
            } else if (expectedType == Map.class) {
                Map<?, ?> map = (Map<?, ?>) object;
                return map != null && map.size() <= 256; // Reasonable size limit
            }

            return true;
        }

        static boolean validateAgainstSchema(Object object, Map<String, Class<?>> schema) {
            Objects.requireNonNull(object, "Object cannot be null");
            Objects.requireNonNull(schema, "Schema cannot be null");

            if (schema.isEmpty()) {
                return true; // No constraints means anything is valid
            }

            // Map input to schema keys
            if (object instanceof Map) {
                Map<?, ?> inputMap = (Map<?, ?>) object;
                for (Map.Entry<String, Class<?>> entry : schema.entrySet()) {
                    Object value = inputMap.get(entry.getKey());
                    if (value != null && !entry.getValue().isAssignableFrom(value.getClass())) {
                        return false;
                    }
                }
                return true;
            }

            // If not a map, check if it matches the expected type
            Class<?> expectedType = schema.values().iterator().next();
            return expectedType.isAssignableFrom(object.getClass());
        }
    }
}