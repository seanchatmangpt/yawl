    private static class StringEncoder implements Encoder<String> {
        @Override
        public ByteBuffer encode(String value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "String value cannot be null");

            byte[] bytes = value.getBytes(java.nio.charset.StandardCharsets.UTF_8);
            ByteBuffer buffer = ByteBuffer.allocate(3 + bytes.length);

            // Type marker for string
            buffer.put((byte) 0x6C);
            // Length
            buffer.putShort((short) bytes.length);
            // String bytes
            buffer.put(bytes);

            buffer.flip();
            return buffer;
        }
    }

    private static class IntegerEncoder implements Encoder<Integer> {
        @Override
        public ByteBuffer encode(Integer value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Integer value cannot be null");

            ByteBuffer buffer = ByteBuffer.allocate(5);

            // Type marker for integer
            buffer.put((byte) 0x69);
            // Value
            buffer.putInt(value);

            buffer.flip();
            return buffer;
        }
    }

    private static class LongEncoder implements Encoder<Long> {
        @Override
        public ByteBuffer encode(Long value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Long value cannot be null");

            ByteBuffer buffer = ByteBuffer.allocate(9);

            // Type marker for long
            buffer.put((byte) 0x6A);
            // Value
            buffer.putLong(value);

            buffer.flip();
            return buffer;
        }
    }

    private static class DoubleEncoder implements Encoder<Double> {
        @Override
        public ByteBuffer encode(Double value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Double value cannot be null");

            ByteBuffer buffer = ByteBuffer.allocate(9);

            // Type marker for float
            buffer.put((byte) 0x6B);
            // Value
            buffer.putDouble(value);

            buffer.flip();
            return buffer;
        }
    }

    private static class BooleanEncoder implements Encoder<Boolean> {
        @Override
        public ByteBuffer encode(Boolean value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Boolean value cannot be null");

            ByteBuffer buffer = ByteBuffer.allocate(2);

            // Type marker for boolean
            buffer.put((byte) 0x70);
            // Value (1 for true, 0 for false)
            buffer.put(value ? (byte) 1 : (byte) 0);

            buffer.flip();
            return buffer;
        }
    }

    private static class ListEncoder implements Encoder<List<?>> {
        @Override
        public ByteBuffer encode(List<?> value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "List value cannot be null");

            // Calculate total size
            int size = 0;
            for (Object item : value) {
                size += calculateItemSize(item);
            }

            ByteBuffer buffer = ByteBuffer.allocate(4 + size);

            // Type marker for list
            buffer.put((byte) 0x6D);
            // Length
            buffer.putInt(value.size());

            // Encode each item
            for (Object item : value) {
                encodeItem(buffer, item);
            }

            buffer.flip();
            return buffer;
        }

        private int calculateItemSize(Object item) {
            // Simplified size calculation
            if (item instanceof String) {
                return 3 + ((String) item).getBytes(java.nio.charset.StandardCharsets.UTF_8).length;
            } else if (item instanceof Integer) {
                return 5;
            } else if (item instanceof Long) {
                return 9;
            } else if (item instanceof Double) {
                return 9;
            } else if (item instanceof Boolean) {
                return 2;
            } else {
                throw new ErlTermCodecException("Unsupported list item type: " + item.getClass());
            }
        }

        private void encodeItem(ByteBuffer buffer, Object item) throws ErlTermCodecException {
            if (item instanceof String) {
                StringEncoder encoder = new StringEncoder();
                ByteBuffer itemBuffer = encoder.encode((String) item);
                buffer.put(itemBuffer);
            } else if (item instanceof Integer) {
                IntegerEncoder encoder = new IntegerEncoder();
                ByteBuffer itemBuffer = encoder.encode((Integer) item);
                buffer.put(itemBuffer);
            } else if (item instanceof Long) {
                LongEncoder encoder = new LongEncoder();
                ByteBuffer itemBuffer = encoder.encode((Long) item);
                buffer.put(itemBuffer);
            } else if (item instanceof Double) {
                DoubleEncoder encoder = new DoubleEncoder();
                ByteBuffer itemBuffer = encoder.encode((Double) item);
                buffer.put(itemBuffer);
            } else if (item instanceof Boolean) {
                BooleanEncoder encoder = new BooleanEncoder();
                ByteBuffer itemBuffer = encoder.encode((Boolean) item);
                buffer.put(itemBuffer);
            } else {
                throw new ErlTermCodecException("Unsupported list item type: " + item.getClass());
            }
        }
    }

    private static class MapEncoder implements Encoder<Map<?, ?>> {
        @Override
        public ByteBuffer encode(Map<?, ?> value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Map value cannot be null");

            // Calculate total size
            int size = 0;
            for (Map.Entry<?, ?> entry : value.entrySet()) {
                size += calculateEntrySize(entry.getKey());
                size += calculateEntrySize(entry.getValue());
            }

            ByteBuffer buffer = ByteBuffer.allocate(4 + size);

            // Type marker for map
            buffer.put((byte) 0x6E);
            // Size
            buffer.putInt(value.size());

            // Encode each entry
            for (Map.Entry<?, ?> entry : value.entrySet()) {
                encodeEntry(buffer, entry.getKey());
                encodeEntry(buffer, entry.getValue());
            }

            buffer.flip();
            return buffer;
        }

        private int calculateEntrySize(Object entry) {
            // Simplified size calculation
            if (entry instanceof String) {
                return 3 + ((String) entry).getBytes(java.nio.charset.StandardCharsets.UTF_8).length;
            } else if (entry instanceof Integer) {
                return 5;
            } else if (entry instanceof Long) {
                return 9;
            } else if (entry instanceof Double) {
                return 9;
            } else if (entry instanceof Boolean) {
                return 2;
            } else {
                throw new ErlTermCodecException("Unsupported map entry type: " + entry.getClass());
            }
        }

        private void encodeEntry(ByteBuffer buffer, Object entry) throws ErlTermCodecException {
            if (entry instanceof String) {
                StringEncoder encoder = new StringEncoder();
                ByteBuffer entryBuffer = encoder.encode((String) entry);
                buffer.put(entryBuffer);
            } else if (entry instanceof Integer) {
                IntegerEncoder encoder = new IntegerEncoder();
                ByteBuffer entryBuffer = encoder.encode((Integer) entry);
                buffer.put(entryBuffer);
            } else if (entry instanceof Long) {
                LongEncoder encoder = new LongEncoder();
                ByteBuffer entryBuffer = encoder.encode((Long) entry);
                buffer.put(entryBuffer);
            } else if (entry instanceof Double) {
                DoubleEncoder encoder = new DoubleEncoder();
                ByteBuffer entryBuffer = encoder.encode((Double) entry);
                buffer.put(entryBuffer);
            } else if (entry instanceof Boolean) {
                BooleanEncoder encoder = new BooleanEncoder();
                ByteBuffer entryBuffer = encoder.encode((Boolean) entry);
                buffer.put(entryBuffer);
            } else {
                throw new ErlTermCodecException("Unsupported map entry type: " + entry.getClass());
            }
        }
    }

    private static class ByteArrayEncoder implements Encoder<byte[]> {
        @Override
        public ByteBuffer encode(byte[] value) throws ErlTermCodecException {
            Objects.requireNonNull(value, "Byte array cannot be null");

            ByteBuffer buffer = ByteBuffer.allocate(4 + value.length);

            // Type marker for binary
            buffer.put((byte) 0x6F);
            // Length
            buffer.putInt(value.length);
            // Bytes
            buffer.put(value);

            buffer.flip();
            return buffer;
        }
    }

    // =============================================================================
    // Built-in Decoders
    // =============================================================================

    private static class StringDecoder implements Decoder<String> {
        @Override
        public String decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6C) {
                throw new ErlTermCodecException("Not a string term");
            }

            // Read length
            short length = buffer.getShort();

            // Read string bytes
            byte[] bytes = new byte[length];
            buffer.get(bytes);

            return new String(bytes, java.nio.charset.StandardCharsets.UTF_8);
        }
    }

    private static class IntegerDecoder implements Decoder<Integer> {
        @Override
        public Integer decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x69) {
                throw new ErlTermCodecException("Not an integer term");
            }

            return buffer.getInt();
        }
    }

    private static class LongDecoder implements Decoder<Long> {
        @Override
        public Long decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6A) {
                throw new ErlTermCodecException("Not a long term");
            }

            return buffer.getLong();
        }
    }

    private static class DoubleDecoder implements Decoder<Double> {
        @Override
        public Double decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6B) {
                throw new ErlTermCodecException("Not a double term");
            }

            return buffer.getDouble();
        }
    }

    private static class BooleanDecoder implements Decoder<Boolean> {
        @Override
        public Boolean decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x70) {
                throw new ErlTermCodecException("Not a boolean term");
            }

            return buffer.get() == 1;
        }
    }

    private static class ListDecoder implements Decoder<List<?>> {
        @Override
        public List<?> decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6D) {
                throw new ErlTermCodecException("Not a list term");
            }

            // Read length
            int length = buffer.getInt();

            // Read items
            List<Object> list = new ArrayList<>(length);
            for (int i = 0; i < length; i++) {
                // Determine item type and decode
                list.add(decodeListItem(buffer));
            }

            return list;
        }

        private Object decodeListItem(ByteBuffer buffer) throws ErlTermCodecException {
            // Look ahead at type marker
            buffer.mark();
            byte typeMarker = buffer.get();
            buffer.reset();

            switch (typeMarker) {
                case 0x6C: // String
                    return new StringDecoder().decode(buffer);
                case 0x69: // Integer
                    return new IntegerDecoder().decode(buffer);
                case 0x6A: // Long
                    return new LongDecoder().decode(buffer);
                case 0x6B: // Double
                    return new DoubleDecoder().decode(buffer);
                case 0x70: // Boolean
                    return new BooleanDecoder().decode(buffer);
                default:
                    throw new ErlTermCodecException("Unknown list item type: " + typeMarker);
            }
        }
    }

    private static class MapDecoder implements Decoder<Map<String, Object>> {
        @Override
        public Map<String, Object> decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6E) {
                throw new ErlTermCodecException("Not a map term");
            }

            // Read size
            int size = buffer.getInt();

            // Read entries
            Map<String, Object> map = new HashMap<>(size);
            for (int i = 0; i < size; i++) {
                // Decode key
                Object key = decodeMapKey(buffer);
                // Decode value
                Object value = decodeMapValue(buffer);

                map.put(key.toString(), value);
            }

            return map;
        }

        private Object decodeMapKey(ByteBuffer buffer) throws ErlTermCodecException {
            // Keys must be strings in Erlang maps
            StringDecoder decoder = new StringDecoder();
            return decoder.decode(buffer);
        }

        private Object decodeMapValue(ByteBuffer buffer) throws ErlTermCodecException {
            // Look ahead at type marker
            buffer.mark();
            byte typeMarker = buffer.get();
            buffer.reset();

            switch (typeMarker) {
                case 0x6C: // String
                    return new StringDecoder().decode(buffer);
                case 0x69: // Integer
                    return new IntegerDecoder().decode(buffer);
                case 0x6A: // Long
                    return new LongDecoder().decode(buffer);
                case 0x6B: // Double
                    return new DoubleDecoder().decode(buffer);
                case 0x70: // Boolean
                    return new BooleanDecoder().decode(buffer);
                default:
                    throw new ErlTermCodecException("Unknown map value type: " + typeMarker);
            }
        }
    }

    private static class ByteArrayDecoder implements Decoder<byte[]> {
        @Override
        public byte[] decode(ByteBuffer buffer) throws ErlTermCodecException {
            Objects.requireNonNull(buffer, "Buffer cannot be null");

            // Check type marker
            if (buffer.get() != 0x6F) {
                throw new ErlTermCodecException("Not a binary term");
            }

            // Read length
            int length = buffer.getInt();

            // Read bytes
            byte[] bytes = new byte[length];
            buffer.get(bytes);

            return bytes;
        }
    }

