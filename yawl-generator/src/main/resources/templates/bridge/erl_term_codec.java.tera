    private static void initializeTypeRegistry() {
        // Register built-in types
        TYPE_REGISTRY.put("String", String.class);
        TYPE_REGISTRY.put("Integer", Integer.class);
        TYPE_REGISTRY.put("Long", Long.class);
        TYPE_REGISTRY.put("Double", Double.class);
        TYPE_REGISTRY.put("Boolean", Boolean.class);
        TYPE_REGISTRY.put("List", List.class);
        TYPE_REGISTRY.put("Map", Map.class);
        TYPE_REGISTRY.put("ByteBuffer", ByteBuffer.class);

        // Register YAWL-specific types
        TYPE_REGISTRY.put("YIdentifier", org.yawlfoundation.yawl.elements.state.YIdentifier.class);
        TYPE_REGISTRY.put("YWorkItem", org.yawlfoundation.yawl.elements.workItem.YWorkItem.class);
        TYPE_REGISTRY.put("YCase", org.yawlfoundation.yawl.case.YCase.class);
    }

    private static void registerEncoders() {
        // String encoder
        registerEncoder(String.class, new StringEncoder());

        // Numeric encoders
        registerEncoder(Integer.class, new IntegerEncoder());
        registerEncoder(Long.class, new LongEncoder());
        registerEncoder(Double.class, new DoubleEncoder());
        registerEncoder(Boolean.class, new BooleanEncoder());

        // Collection encoders
        registerEncoder(List.class, new ListEncoder());
        registerEncoder(Map.class, new MapEncoder());

        // Byte array encoder
        registerEncoder(byte[].class, new ByteArrayEncoder());
    }

    private static void registerDecoders() {
        // String decoder
        registerDecoder(String.class, new StringDecoder());

        // Numeric decoders
        registerDecoder(Integer.class, new IntegerDecoder());
        registerDecoder(Long.class, new LongDecoder());
        registerDecoder(Double.class, new DoubleDecoder());
        registerDecoder(Boolean.class, new BooleanDecoder());

        // Collection decoders
        registerDecoder(List.class, new ListDecoder());
        registerDecoder(Map.class, new MapDecoder());

        // Byte array decoder
        registerDecoder(byte[].class, new ByteArrayDecoder());
    }

    private static void validateCodecInitialization() {
        // Validate all required encoders/decoders are registered
        if (ENCODERS.isEmpty() || DECODERS.isEmpty()) {
            throw new IllegalStateException("Codec initialization failed: no encoders/decoders registered");
        }

        // Validate type registry consistency
        if (TYPE_REGISTRY.isEmpty()) {
            throw new IllegalStateException("Codec initialization failed: type registry empty");
        }
    }

    private static void validateBeforeEncoding(Object object, Class<?> clazz) {
        ErlangTermValidator.validateObject(object, clazz);
    }

    private static void validateAfterDecoding(Object object) {
        ErlangTermValidator.validateObject(object, object.getClass());
    }

    private static void validateEncodedBuffer(ByteBuffer buffer) {
        if (buffer == null || buffer.remaining() == 0) {
            throw new ErlTermCodecException("Encoded buffer is null or empty");
        }
    }

    private static void validateInputBuffer(ByteBuffer buffer) {
        if (buffer == null || buffer.remaining() == 0) {
            throw new ErlTermCodecException("Input buffer is null or empty");
        }

        // Check minimum length for valid Erlang term
        if (buffer.remaining() < 2) {
            throw new ErlTermCodecException("Buffer too short for valid Erlang term");
        }

        // Check magic byte
        if (buffer.get() != 0x83) {
            throw new ErlTermCodecException("Invalid magic byte in Erlang term");
        }

        // Check version
        if (buffer.get() != 0x69) {
            throw new ErlTermCodecException("Invalid version in Erlang term");
        }
    }

    private static Object decodeBuffer(ByteBuffer buffer) {
        // Create reader position marker
        buffer.mark();

        try {
            // Decode based on type marker
            byte typeMarker = buffer.get();

            switch (typeMarker) {
                case 0x83: // Small integer
                    return buffer.get() & 0xFF;
                case 0x69: // Integer
                    return buffer.getInt();
                case 0x6A: // Long
                    return buffer.getLong();
                case 0x6B: // Float
                    return buffer.getDouble();
                case 0x70: // Boolean
                    return buffer.get() == 1;
                case 0x6C: // String
                    int length = buffer.getShort();
                    byte[] stringBytes = new byte[length];
                    buffer.get(stringBytes);
                    return new String(stringBytes, java.nio.charset.StandardCharsets.UTF_8);
                default:
                    throw new ErlTermCodecException("Unknown type marker: " + typeMarker);
            }
        } finally {
            buffer.reset();
        }
    }

    // =============================================================================
    // Encoder/Decoder Interfaces
    // =============================================================================

    public interface Encoder<T> {
        ByteBuffer encode(T value) throws ErlTermCodecException;
    }

    public interface Decoder<T> {
        T decode(ByteBuffer buffer) throws ErlTermCodecException;
    }

    // =============================================================================
    // Built-in Encoders
