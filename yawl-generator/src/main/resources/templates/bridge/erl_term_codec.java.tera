    /**
     * Encode Java object to Erlang term byte representation
     *
     * @param object Java object to encode
     * @return Erlang term as byte array
     * @throws ErlTermCodecException if encoding fails validation
     */
    public static synchronized byte[] encode(Object object) throws ErlTermCodecException {
        Objects.requireNonNull(object, "Object to encode cannot be null");

        try {
            Class<?> clazz = object.getClass();
            Encoder<?> encoder = ENCODERS.get(clazz);

            if (encoder == null) {
                throw new ErlTermCodecException(
                    "No encoder registered for type: " + clazz.getName()
                );
            }

            // Validate object before encoding
            validateBeforeEncoding(object, clazz);

            // Encode to Erlang term
            ByteBuffer buffer = (ByteBuffer) encoder.encode(object);

            // Validate encoded result
            validateEncodedBuffer(buffer);

            return buffer.array();
        } catch (Exception e) {
            throw new ErlTermCodecException(
                "Failed to encode object of type: " + object.getClass().getName(),
                e
            );
        }
    }

    /**
     * Decode Erlang term byte representation to Java object
     *
     * @param bytes Erlang term byte array
     * @return Decoded Java object
     * @throws ErlTermCodecException if decoding fails validation
     */
    public static synchronized <T> T decode(byte[] bytes) throws ErlTermCodecException {
        Objects.requireNonNull(bytes, "Bytes to decode cannot be null");

        try {
            ByteBuffer buffer = ByteBuffer.wrap(bytes);

            // Validate input buffer
            validateInputBuffer(buffer);

            // Decode buffer to Java object
            Object decoded = decodeBuffer(buffer);

            // Validate decoded object
            validateAfterDecoding(decoded);

            //noinspection unchecked
            return (T) decoded;
        } catch (Exception e) {
            throw new ErlTermCodecException(
                "Failed to decode Erlang term",
                e
            );
        }
    }

    /**
     * Validate Erlang term is properly encoded
     *
     * @param bytes Erlang term byte array to validate
     * @return true if valid, throws exception otherwise
     * @throws ErlTermCodecException if validation fails
     */
    public static synchronized boolean isValidEncoding(byte[] bytes) throws ErlTermCodecException {
        Objects.requireNonNull(bytes, "Bytes to validate cannot be null");

        try {
            // Check minimum length for valid Erlang term
            if (bytes.length < 2) {
                return false;
            }

            // Check magic byte
            if (bytes[0] != 0x83) { // External term format magic
                return false;
            }

            // Validate version
            if (bytes[1] != 0x69) { // Version 131
                return false;
            }

            // Validate term structure
            return ErlangTermValidator.validateTerm(bytes);
        } catch (Exception e) {
            throw new ErlTermCodecException(
                "Validation failed for Erlang term",
                e
            );
        }
    }

    /**
     * Validate Java object can be encoded
     *
     * @param object Java object to validate
     * @return true if valid, throws exception otherwise
     * @throws ErlTermCodecException if validation fails
     */
    public static synchronized boolean isValidEncoding(Object object) throws ErlTermCodecException {
        Objects.requireNonNull(object, "Object to validate cannot be null");

        try {
            // Check if encoder exists
            Class<?> clazz = object.getClass();
            if (!ENCODERS.containsKey(clazz)) {
                return false;
            }

            // Validate object against schema
            return ErlangTermValidator.validateObject(object, clazz);
        } catch (Exception e) {
            throw new ErlTermCodecException(
                "Validation failed for Java object",
                e
            );
        }
    }

