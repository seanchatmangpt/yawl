/**
 * {{ bridgeName }}CapabilityRegistry — startup gate for the {{ bridgeName }} native bridge.
 *
 * <p>Scans registered L2/L3 class lists for {@code @MapsToCapability} annotations and
 * test classes for {@code @CapabilityTest} annotations, then verifies that every
 * {@link {{ bridgeName }}Capability} (except {@code TOTAL}) has all three coverages.</p>
 *
 * <p>If any capability is missing, {@link #validate()} throws
 * {@link {{ bridgeName }}CapabilityRegistryException}, aborting startup with a full report.</p>
 *
 * <p>Usage:
 * <pre>
 *   {{ bridgeName }}CapabilityRegistry registry = new {{ bridgeName }}CapabilityRegistry(
 *       List.of({{ l2Class }}.class),
 *       List.of({{ l3Class }}.class),
 *       List.of({{ testClass }}.class));
 *   registry.validate();
 * </pre>
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-02
 */
package {{ packageName }};

import java.lang.reflect.Method;
import java.util.ArrayList;
import java.util.EnumSet;
import java.util.List;
import java.util.Set;

public final class {{ bridgeName }}CapabilityRegistry {

    private final List<Class<?>> layer2Classes;
    private final List<Class<?>> layer3Classes;
    private final List<Class<?>> testClasses;

    /**
     * Creates a registry with the given class lists.
     *
     * @param layer2Classes FFI transport layer classes (may use Panama MemorySegment internally)
     * @param layer3Classes domain API layer classes (pure Java public signatures)
     * @param testClasses   classes containing {@code @{{ bridgeName }}CapabilityTest}-annotated methods
     * @throws IllegalArgumentException if any argument is null
     */
    public {{ bridgeName }}CapabilityRegistry(
            List<Class<?>> layer2Classes,
            List<Class<?>> layer3Classes,
            List<Class<?>> testClasses) {
        if (layer2Classes == null) {
            throw new IllegalArgumentException("layer2Classes must not be null");
        }
        if (layer3Classes == null) {
            throw new IllegalArgumentException("layer3Classes must not be null");
        }
        if (testClasses == null) {
            throw new IllegalArgumentException("testClasses must not be null");
        }
        this.layer2Classes = List.copyOf(layer2Classes);
        this.layer3Classes = List.copyOf(layer3Classes);
        this.testClasses   = List.copyOf(testClasses);
    }

    /**
     * Validates that all capabilities are implemented and tested.
     *
     * @throws {{ bridgeName }}CapabilityRegistryException if any capability is missing L2, L3, or test coverage
     */
    public void validate() {
        Set<{{ bridgeName }}Capability> coveredL2   = EnumSet.noneOf({{ bridgeName }}Capability.class);
        Set<{{ bridgeName }}Capability> coveredL3   = EnumSet.noneOf({{ bridgeName }}Capability.class);
        Set<{{ bridgeName }}Capability> coveredTest = EnumSet.noneOf({{ bridgeName }}Capability.class);

        for (Class<?> cls : layer2Classes) {
            scanMapsToCapability(cls, coveredL2);
        }
        for (Class<?> cls : layer3Classes) {
            scanMapsToCapability(cls, coveredL3);
        }
        for (Class<?> cls : testClasses) {
            scanCapabilityTests(cls, coveredTest);
        }

        List<String> missing = new ArrayList<>();
        for ({{ bridgeName }}Capability cap : {{ bridgeName }}Capability.values()) {
            if (cap == {{ bridgeName }}Capability.TOTAL) {
                continue;
            }
            if (!coveredL2.contains(cap)) {
                missing.add("L2 missing: " + cap.name());
            }
            if (!coveredL3.contains(cap)) {
                missing.add("L3 missing: " + cap.name());
            }
            if (!coveredTest.contains(cap)) {
                missing.add("Test missing: " + cap.name());
            }
        }

        if (!missing.isEmpty()) {
            throw new {{ bridgeName }}CapabilityRegistryException(missing);
        }
    }

    private void scanMapsToCapability(Class<?> cls, Set<{{ bridgeName }}Capability> target) {
        {{ bridgeName }}MapsToCapability single = cls.getAnnotation({{ bridgeName }}MapsToCapability.class);
        if (single != null) {
            target.add(single.value());
        }
        {{ bridgeName }}MapsToCapability.Repeatable container =
            cls.getAnnotation({{ bridgeName }}MapsToCapability.Repeatable.class);
        if (container != null) {
            for ({{ bridgeName }}MapsToCapability ann : container.value()) {
                target.add(ann.value());
            }
        }
        for (Method method : cls.getDeclaredMethods()) {
            {{ bridgeName }}MapsToCapability ms = method.getAnnotation({{ bridgeName }}MapsToCapability.class);
            if (ms != null) {
                target.add(ms.value());
            }
            {{ bridgeName }}MapsToCapability.Repeatable mc =
                method.getAnnotation({{ bridgeName }}MapsToCapability.Repeatable.class);
            if (mc != null) {
                for ({{ bridgeName }}MapsToCapability ann : mc.value()) {
                    target.add(ann.value());
                }
            }
        }
    }

    private void scanCapabilityTests(Class<?> cls, Set<{{ bridgeName }}Capability> target) {
        for (Method method : cls.getDeclaredMethods()) {
            {{ bridgeName }}CapabilityTest single =
                method.getAnnotation({{ bridgeName }}CapabilityTest.class);
            if (single != null) {
                target.add(single.value());
            }
            {{ bridgeName }}CapabilityTest.Repeatable container =
                method.getAnnotation({{ bridgeName }}CapabilityTest.Repeatable.class);
            if (container != null) {
                for ({{ bridgeName }}CapabilityTest ann : container.value()) {
                    target.add(ann.value());
                }
            }
        }
    }
}
