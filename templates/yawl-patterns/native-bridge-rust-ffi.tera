fn to_cstr(s: String) -> *mut c_char {
    CString::new(s)
        .unwrap_or_else(|_| CString::new(r#"{"error":"encoding_error"}"#).unwrap())
        .into_raw()
}

fn null_error() -> *mut c_char {
    to_cstr(r#"{"error":"null_input","message":"json argument is null"}"#.to_string())
}

/// Free a string returned by this library.
/// MUST be called for every non-null *mut c_char returned by dm_* functions.
#[no_mangle]
pub unsafe extern "C" fn dm_string_free(ptr: *mut c_char) {
    if !ptr.is_null() {
        drop(CString::from_raw(ptr));
    }
}

