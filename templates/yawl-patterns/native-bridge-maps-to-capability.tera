  Template: YNativeBridgeMapsToCapability.java
  Pattern: Native Bridge — MapsToCapability Annotation (WCP-NB-05)
  Description: Repeatable annotation declaring that a class or method implements
               a specific bridge capability at a defined bridge layer (L2 or L3).
               Scanned by CapabilityRegistry at startup for all-or-nothing validation.
#}
/**
 * Declares that a class or method implements a specific {@link {{ bridgeName }}Capability} at
 * a defined bridge layer.
 *
 * <p>The {@link {{ bridgeName }}CapabilityRegistry} scans all registered classes for this
 * annotation at startup. For each declared {@link {{ bridgeName }}Capability} (except
 * {@link {{ bridgeName }}Capability#TOTAL}), there must be at least one annotated element with
 * {@code layer = "L2"} and at least one with {@code layer = "L3"}. Missing either causes
 * the registry to throw {@link {{ bridgeName }}CapabilityRegistryException}.</p>
 *
 * <p>Usage on a class (coarse-grained, for L2 where one class handles many capabilities):
 * <pre>
 *   &#64;{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.SOME_CAP, layer = "L2")
 *   &#64;{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.OTHER_CAP, layer = "L2")
 *   public class {{ bridgeName }}L2 { ... }
 * </pre>
 *
 * <p>Usage on a method (fine-grained, preferred for L3 public API):
 * <pre>
 *   &#64;{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.SOME_CAP, layer = "L3")
 *   public String someCapability(String request) { ... }
 * </pre>
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-05
 * @see {{ bridgeName }}CapabilityRegistry
 * @see {{ bridgeName }}Capability
 */
package {{ packageName }};

import java.lang.annotation.Documented;
import java.lang.annotation.ElementType;
import java.lang.annotation.Repeatable;
import java.lang.annotation.Retention;
import java.lang.annotation.RetentionPolicy;
import java.lang.annotation.Target;

@Documented
@Repeatable({{ bridgeName }}MapsToCapability.Repeatable.class)
@Target({ElementType.TYPE, ElementType.METHOD})
@Retention(RetentionPolicy.RUNTIME)
public @interface {{ bridgeName }}MapsToCapability {

    /** The capability this element implements. */
    {{ bridgeName }}Capability value();

    /**
     * The bridge layer this implementation belongs to.
     *
     * <p>Must be exactly {@code "L2"} (FFI transport, Panama FFM types allowed internally)
     * or {@code "L3"} (domain API, no Panama FFM types in public signatures).</p>
     */
    String layer();

    /** Container for repeated {@link {{ bridgeName }}MapsToCapability} annotations. */
    @Documented
    @Target({ElementType.TYPE, ElementType.METHOD})
    @Retention(RetentionPolicy.RUNTIME)
    @interface Repeatable {
        {{ bridgeName }}MapsToCapability[] value();
    }
}
