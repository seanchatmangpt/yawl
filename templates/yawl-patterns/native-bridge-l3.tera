/**
 * {{ bridgeName }}L3 — Layer 3 domain API for {{ domainDescription }}.
 *
 * <p>All public method signatures use only standard Java types (String, List, Map,
 * records). No Panama FFM types (MemorySegment, Arena) appear at the call site.
 * Internal delegation goes to {@link {{ bridgeName }}L2} (Layer 2 FFI transport).</p>
 *
 * <p>Architecture:
 * <pre>
 *   application code
 *        ↓ calls
 *   L3 domain API ({{ bridgeName }}L3)   ← this class
 *        ↓ delegates
 *   L2 FFI transport ({{ bridgeName }}L2)
 *        ↓ downcall
 *   {{ nativeLibrary }} (native)
 * </pre>
 *
 * <p>Thread-safe: internally synchronises on the L2 transport lock.
 * Suitable for multi-threaded callers.</p>
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-04
 * @see {{ bridgeName }}L2
 */
package {{ packageName }};

import java.util.List;
import java.util.Map;
import java.util.Objects;
{% for import in extraImports %}
import {{ import }};
{% endfor %}

{% for cap in capabilities %}
@{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.{{ cap.name }}, layer = "L3")
{% endfor %}
public final class {{ bridgeName }}L3 implements AutoCloseable {

    private final {{ bridgeName }}L2 transport;
    private volatile boolean closed = false;

    /**
     * Creates a domain API backed by the given L2 transport.
     *
     * @param transport connected L2 FFI transport; must not be null
     * @throws IllegalArgumentException if transport is null
     */
    public {{ bridgeName }}L3({{ bridgeName }}L2 transport) {
        if (transport == null) {
            throw new IllegalArgumentException("transport must not be null");
        }
        this.transport = transport;
    }

    /**
     * Creates a domain API, loading the native library from the system property
     * {@value {{ bridgeName }}L2#LIB_PATH_PROP}.
     *
     * @return connected {{ bridgeName }}L3
     */
    public static {{ bridgeName }}L3 fromSystemProperty() {
        String libPath = System.getProperty({{ bridgeName }}L2.LIB_PATH_PROP);
        return new {{ bridgeName }}L3(new {{ bridgeName }}L2(libPath));
    }

    private void requireOpen() {
        if (closed) {
            throw new IllegalStateException("{{ bridgeName }}L3 is closed");
        }
    }

{% for op in operations %}
    /**
     * {{ op.description }}
     *
{% for param in op.params %}
     * @param {{ param.name }} {{ param.description }}
{% endfor %}
     * @return {{ op.returnDoc }}
     * @throws {{ op.exceptionType }} if the native operation fails
     * @throws IllegalStateException if this bridge has been closed
     */
    public {{ op.returnType }} {{ op.name }}({% for param in op.params %}{{ param.type }} {{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %}) throws {{ op.exceptionType }} {
        requireOpen();
{% for param in op.params %}
{% if param.required %}
        Objects.requireNonNull({{ param.name }}, "{{ param.name }} must not be null");
{% endif %}
{% endfor %}
        try {
            {{ op.impl }}
        } catch ({{ op.nativeException }} e) {
            throw new {{ op.exceptionType }}(
                "{{ op.name }} failed: " + e.getMessage(), e);
        }
    }

{% endfor %}

    /**
     * Returns true if the underlying native library is available.
     */
    public boolean isAvailable() {
        return transport.isLibraryLoaded();
    }

    /**
     * Closes the underlying L2 transport and releases native resources.
     */
    @Override
    public void close() {
        if (!closed) {
            closed = true;
            transport.close();
        }
    }
}
