{#
  Template: YNativeBridgeCapabilityTest.java
  Pattern: Native Bridge — CapabilityTest Annotation (WCP-NB-06)
  Description: Repeatable annotation marking a test method as validating a
               specific bridge capability. Scanned by CapabilityRegistry at startup
               to enforce that every capability has at least one test.
#}
/**
 * Marks a test method as validating a specific {@link {{ bridgeName }}Capability}.
 *
 * <p>The {@link {{ bridgeName }}CapabilityRegistry} scans all registered test classes for this
 * annotation. For each declared {@link {{ bridgeName }}Capability} (except
 * {@link {{ bridgeName }}Capability#TOTAL}), there must be at least one test method annotated
 * with {@code @{{ bridgeName }}CapabilityTest({{ bridgeName }}Capability.SOME_CAP)}. If any
 * capability lacks a test, the registry throws
 * {@link {{ bridgeName }}CapabilityRegistryException}.</p>
 *
 * <p>Example:
 * <pre>
 *   &#64;Test
 *   &#64;{{ bridgeName }}CapabilityTest({{ bridgeName }}Capability.SOME_CAP)
 *   void someCapability_roundTripsJson() {
 *       String result = bridge.someCapability("{\"key\":\"value\"}");
 *       assertThat(result).isNotBlank();
 *   }
 * </pre>
 *
 * <p>The registry does not enforce the quality of test assertions — that is a
 * code review responsibility.</p>
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-06
 * @see {{ bridgeName }}CapabilityRegistry
 * @see {{ bridgeName }}Capability
 * @see {{ bridgeName }}MapsToCapability
 */
package {{ packageName }};

import java.lang.annotation.Documented;
import java.lang.annotation.ElementType;
import java.lang.annotation.Repeatable;
import java.lang.annotation.Retention;
import java.lang.annotation.RetentionPolicy;
import java.lang.annotation.Target;

@Documented
@Repeatable({{ bridgeName }}CapabilityTest.Repeatable.class)
@Target(ElementType.METHOD)
@Retention(RetentionPolicy.RUNTIME)
public @interface {{ bridgeName }}CapabilityTest {

    /** The capability validated by this test method. */
    {{ bridgeName }}Capability value();

    /** Container for repeated {@link {{ bridgeName }}CapabilityTest} annotations. */
    @Documented
    @Target(ElementType.METHOD)
    @Retention(RetentionPolicy.RUNTIME)
    @interface Repeatable {
        {{ bridgeName }}CapabilityTest[] value();
    }
}
