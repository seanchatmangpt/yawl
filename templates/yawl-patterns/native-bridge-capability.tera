{#
  Template: YNativeBridgeCapability.java
  Pattern: Native Bridge — Capability Enum (WCP-NB-01)
  Description: Declares all capabilities that cross a native library boundary.
               Each capability must have L2 (FFI transport) + L3 (domain API) + test coverage.
#}
/**
 * {{ bridgeName }}Capability — all native bridge capabilities for the {{ bridgeName }} module.
 *
 * <p>Correctness-by-construction: every value (except {@link #TOTAL}) must have:
 * <ol>
 *   <li>A Layer 2 implementation annotated {@code @MapsToCapability(layer="L2")}</li>
 *   <li>A Layer 3 implementation annotated {@code @MapsToCapability(layer="L3")}</li>
 *   <li>At least one test method annotated {@code @CapabilityTest(CAPABILITY)}</li>
 * </ol>
 *
 * <p>The {@link {{ bridgeName }}CapabilityRegistry} validates this contract at startup
 * and throws {@link {{ bridgeName }}CapabilityRegistryException} if any requirement is unmet.</p>
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-01
 */
package {{ packageName }};

public enum {{ bridgeName }}Capability {

{% for cap in capabilities %}
    /**
     * {{ cap.description }}
     * Native call: {{ cap.nativeTarget }}
     */
    {{ cap.name }},

{% endfor %}
    /**
     * Sentinel value — counts declared capabilities.
     * Never annotated on any implementation class.
     * Use {@code {{ bridgeName }}Capability.TOTAL.ordinal()} to count real capabilities.
     */
    TOTAL
}
