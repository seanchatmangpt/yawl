/**
 * {{ bridgeName }}L2 — Layer 2 FFI transport for the {{ nativeLibrary }} native library.
 *
 * <p>Thin wrapper over Panama FFM downcall handles. Every public method maps
 * 1-to-1 to a native symbol in {@code {{ nativeLibrary }}}. No business logic lives here.
 *
 * <p>Architecture:
 * <pre>
 *   L3 domain API ({{ bridgeName }}L3)
 *        ↓ delegates
 *   L2 FFI transport ({{ bridgeName }}L2)   ← this class
 *        ↓ downcall
 *   {{ nativeLibrary }} (native)
 * </pre>
 *
 * <p>Graceful degradation: all methods throw {@link UnsupportedOperationException}
 * when the native library is not loaded. Set system property
 * {@code -D{{ libraryPathProp }}=/path/to/{{ nativeLibrary }}} to enable native operations.
 *
 * @generated by ggen from ontology
 * @pattern WCP-NB-03
 * @see {{ bridgeName }}L3
 */
package {{ packageName }};

import java.lang.foreign.Arena;
import java.lang.foreign.FunctionDescriptor;
import java.lang.foreign.Linker;
import java.lang.foreign.MemorySegment;
import java.lang.foreign.SymbolLookup;
import java.lang.invoke.MethodHandle;
import java.nio.file.Path;
import java.util.Optional;

@{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.{% for cap in capabilities %}{{ cap.name }}{% if not loop.last %}, layer = "L2")
@{{ bridgeName }}MapsToCapability(value = {{ bridgeName }}Capability.{% endif %}{% endfor %}, layer = "L2")
public final class {{ bridgeName }}L2 implements AutoCloseable {

    /** System property for the path to {@code {{ nativeLibrary }}}. */
    public static final String LIB_PATH_PROP = "{{ libraryPathProp }}";

    private static final Linker LINKER = Linker.nativeLinker();
    private final Arena arena;
    private final Optional<SymbolLookup> library;

{% for fn in functions %}
    /** Downcall handle for {@code {{ fn.nativeSymbol }}}. */
    private final MethodHandle {{ fn.handleName }};
{% endfor %}

    /**
     * Creates an L2 transport with the native library loaded from the given path.
     * If the path is null or blank, all operations will throw {@link UnsupportedOperationException}.
     *
     * @param libraryPath absolute path to {@code {{ nativeLibrary }}}, or null to operate degraded
     */
    public {{ bridgeName }}L2(String libraryPath) {
        this.arena = Arena.ofShared();
        Optional<SymbolLookup> lib = Optional.empty();
        if (libraryPath != null && !libraryPath.isBlank()) {
            lib = Optional.of(SymbolLookup.libraryLookup(Path.of(libraryPath), arena));
        }
        this.library = lib;

{% for fn in functions %}
        this.{{ fn.handleName }} = library.isPresent()
            ? resolveHandle("{{ fn.nativeSymbol }}", {{ fn.descriptor }})
            : null;
{% endfor %}
    }

    private MethodHandle resolveHandle(String symbol, FunctionDescriptor descriptor) {
        return library.get().find(symbol)
            .map(seg -> LINKER.downcallHandle(seg, descriptor))
            .orElseThrow(() -> new UnsatisfiedLinkError(
                symbol + " not found in {{ nativeLibrary }}"));
    }

    private void requireLibrary() {
        if (library.isEmpty()) {
            throw new UnsupportedOperationException(
                "{{ nativeLibrary }} not loaded. Set -D" + LIB_PATH_PROP + "=/path/to/{{ nativeLibrary }}");
        }
    }

{% for fn in functions %}
    /**
     * Calls {@code {{ fn.nativeSymbol }}}{% if fn.description %} — {{ fn.description }}{% endif %}.
     *
{% for param in fn.params %}
     * @param {{ param.name }} {{ param.description }}
{% endfor %}
     * @return {{ fn.returnDoc }}
     * @throws UnsupportedOperationException if {{ nativeLibrary }} is not loaded
     * @throws AssertionError if the downcall handle invocation fails unexpectedly
     */
    public {{ fn.returnType }} {{ fn.javaName }}({% for param in fn.params %}{{ param.type }} {{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %}) {
        requireLibrary();
        try {
{% if fn.returnType == "void" %}
            {{ fn.handleName }}.invokeExact({% for param in fn.params %}{{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %});
{% else %}
            return ({{ fn.returnType }}) {{ fn.handleName }}.invokeExact({% for param in fn.params %}{{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %});
{% endif %}
        } catch (Throwable t) {
            throw new AssertionError("{{ fn.nativeSymbol }} invocation failed", t);
        }
    }

{% endfor %}

    /**
     * Returns true if the native library was successfully loaded.
     */
    public boolean isLibraryLoaded() {
        return library.isPresent();
    }

    /**
     * Releases the shared Arena holding all native memory segments.
     * After closing, all method calls will throw {@link IllegalStateException}.
     */
    @Override
    public void close() {
        arena.close();
    }
}
