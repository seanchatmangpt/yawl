# SHACL Shapes for HIPAA Compliance (Health Insurance Portability and Accountability Act)
# These shapes define YAWL workflow requirements for healthcare data privacy

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix yawl: <http://www.yawlfoundation.org/yawl#> .
@prefix hipaa: <http://www.yawlfoundation.org/hipaa#> .

# Base shapes
hipaa:ComplianceShape a sh:NodeShape ;
    rdfs:label "HIPAA Compliance Shape" ;
    rdfs:comment "Base shape for HIPAA compliance requirements" ;
    sh:severity sh:Violation ;
    sh:message "HIPAA compliance violation detected" ;
    sh:closed true ;
    sh:ignoredProperties (rdf:type) .

# Healthcare Process Shape
hipaa:HealthcareProcessShape a sh:NodeShape ;
    rdfs:label "Healthcare Process" ;
    rdfs:comment "YAWL process that handles healthcare data" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Healthcare process must comply with HIPAA requirements" ;
    sh:property [
        sh:path yawl:hasTask ;
        sh:node hipaa:HealthcareTaskShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Healthcare process must contain at least one healthcare task" ;
    ] ;
    sh:property [
        sh:path yawl:hasPHI ;
        hasValue true ;
        severity sh:Violation ;
        message "Process must declare Protected Health Information (PHI) handling" ;
    ] ;
    sh:property [
        sh:path yawl:hasSecurity ;
        sh:node hipaa:SecurityShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "HIPAA security requirements must be met" ;
    ] ;
    sh:property [
        sh:path yawl:hasPrivacy ;
        sh:node hipaa:PrivacyShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "HIPAA privacy requirements must be met" ;
    ] .

# Healthcare Task Shape
hipaa:HealthcareTaskShape a sh:NodeShape ;
    rdfs:label "Healthcare Task" ;
    rdfs:comment "Task that handles healthcare data" ;
    sh:targetClass yawl:Task ;
    sh:severity sh:Violation ;
    sh:message "Healthcare task must comply with HIPAA requirements" ;
    sh:property [
        sh:path yawl:handlesPHI ;
        hasValue true ;
        severity sh:Violation ;
        message "Task must declare PHI handling" ;
    ] ;
    sh:property [
        sh:path yawl:hasAccessControl ;
        sh:node hipaa:AccessControlShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Access controls required for healthcare data" ;
    ] ;
    sh:property [
        sh:path yawl:hasAuditLog ;
        sh:node hipaa:AuditLogShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Audit logs required for healthcare data" ;
    ] ;
    sh:property [
        sh:path yawl:hasEncryption ;
        sh:node hipaa:EncryptionShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Encryption required for healthcare data" ;
    ] .

# Security Rule Shape
hipaa:SecurityShape a sh:NodeShape ;
    rdfs:label "Security Rule" ;
    rdfs:comment "HIPAA Security Rule requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:hasAdministrative ;
        sh:node hipaa:AdministrativeShape ;
        severity sh:Warning ;
        message "Administrative safeguards should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasPhysical ;
        sh:node hipaa:PhysicalShape ;
        severity sh:Warning ;
        message "Physical safeguards should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasTechnical ;
        sh:node hipaa:TechnicalShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Technical safeguards required" ;
    ] .

# Administrative Safeguards Shape
hipaa:AdministrativeShape a sh:NodeShape ;
    rdfs:label "Administrative Safeguards" ;
    rdfs:comment "HIPAA Administrative Safeguards" ;
    sh:severity sh:Warning ;
    sh:property [
        sh:path yawl:hasSecurityManagement ;
        minCount 1 ;
        severity sh:Warning ;
        message "Security management process should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:hasWorkforceTraining ;
        minCount 1 ;
        severity sh:Warning ;
        message "Workforce training should be provided" ;
    ] ;
    sh:property [
        sh:path yawl:hasSanctionPolicy ;
        minCount 1 ;
        severity sh:Warning ;
        message "Sanction policy should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:hasRiskManagement ;
        minCount 1 ;
        severity sh:Warning ;
        message "Risk management should be implemented" ;
    ] .

# Physical Safeguards Shape
hipaa:PhysicalShape a sh:NodeShape ;
    rdfs:label "Physical Safeguards" ;
    rdfs:comment "HIPAA Physical Safeguards" ;
    sh:severity sh:Warning ;
    sh:property [
        sh:path yawl:hasAccessControl ;
        minCount 1 ;
        severity sh:Warning ;
        message "Physical access control should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasWorkstationSecurity ;
        minCount 1 ;
        severity sh:Warning ;
        message "Workstation security should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasDeviceSecurity ;
        minCount 1 ;
        severity sh:Warning ;
        message "Device security should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasMediaControls ;
        minCount 1 ;
        severity sh:Warning ;
        message "Media controls should be implemented" ;
    ] .

# Technical Safeguards Shape
hipaa:TechnicalShape a sh:NodeShape ;
    rdfs:label "Technical Safeguards" ;
    rdfs:comment "HIPAA Technical Safeguards" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:hasAccessControl ;
        sh:node hipaa:AccessControlShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Access controls required" ;
    ] ;
    sh:property [
        sh:path yawl:hasAuditControls ;
        sh:node hipaa:AuditControlShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Audit controls required" ;
    ] ;
    sh:property [
        sh:path yawl:hasIntegrity ;
        minCount 1 ;
        severity sh:Warning ;
        message "Integrity controls should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:hasTransmission ;
        sh:node hipaa:TransmissionShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Transmission security required" ;
    ] ;
    sh:property [
        sh:path yawl:hasStorage ;
        sh:node hipaa:StorageShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Storage security required" ;
    ] .

# Privacy Rule Shape
hipaa:PrivacyShape a sh:NodeShape ;
    rdfs:label "Privacy Rule" ;
    rdfs:comment "HIPAA Privacy Rule requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:hasNotice ;
        minCount 1 ;
        severity sh:Violation ;
        message "Privacy notice required" ;
    ] ;
    sh:property [
        sh:path yawl:hasAuthorization ;
        minCount 1 ;
        severity sh:Violation ;
        message "Authorization required" ;
    ] ;
    sh:property [
        sh:path yawl:hasAccounting ;
        sh:node hipaa:AccountingShape ;
        severity sh:Warning ;
        message "Accounting of disclosures should be maintained" ;
    ] ;
    sh:property [
        sh:path yawl:hasMinimumNecessary ;
        minCount 1 ;
        severity sh:Violation ;
        message "Minimum necessary standard required" ;
    ] ;
    sh:property [
        sh:path yawl:hasBusinessAssociate ;
        minCount 1 ;
        severity sh:Warning ;
        message "Business associate agreements should be in place" ;
    ] .

# Access Control Shape
hipaa:AccessControlShape a sh:NodeShape ;
    rdfs:label "Access Control" ;
    rdfs:comment "HIPAA access control requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:uniqueUserIdentifier ;
        minCount 1 ;
        severity sh:Violation ;
        message "Unique user identifier required" ;
    ] ;
    sh:property [
        sh:path yawl:emergencyAccess ;
        minCount 1 ;
        severity sh:Warning ;
        message "Emergency access procedures should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:automaticLogoff ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Automatic logoff should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:encryption ;
        sh:node hipaa:EncryptionShape ;
        severity sh:Warning ;
        message "Encryption should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:activityReview ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Activity review should be implemented" ;
    ] .

# Audit Control Shape
hipaa:AuditControlShape a sh:NodeShape ;
    rdfs:label "Audit Control" ;
    rdfs:comment "HIPAA audit control requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:auditTrail ;
        minCount 1 ;
        severity sh:Violation ;
        message "Audit trail required" ;
    ] ;
    sh:property [
        sh:path yawl:auditRetention ;
        minInclusive 6 ;
        severity sh:Violation ;
        message "Audit trail retention minimum 6 years" ;
    ] ;
    sh:property [
        sh:path yawl:auditMonitoring ;
        minCount 1 ;
        severity sh:Warning ;
        message "Audit monitoring should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:auditReview ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Audit review should be implemented" ;
    ] .

# Encryption Shape
hipaa:EncryptionShape a sh:NodeShape ;
    rdfs:label "Encryption" ;
    rdfs:comment "HIPAA encryption requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:encryptTransit ;
        hasValue true ;
        severity sh:Violation ;
        message "Encryption in transit required" ;
    ] ;
    sh:property [
        sh:path yawl:encryptAtRest ;
        hasValue true ;
        severity sh:Warning ;
        message "Encryption at rest should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:encryptAlgorithm ;
        in ("AES-256", "AES-192", "AES-128", "3DES", "RSA-2048") ;
        severity sh:Warning ;
        message "Encryption algorithm should be strong" ;
    ] ;
    sh:property [
        sh:path yawl:keyManagement ;
        minCount 1 ;
        severity sh:Violation ;
        message "Key management required" ;
    ] .

# Transmission Security Shape
hipaa:TransmissionShape a sh:NodeShape ;
    rdfs:label "Transmission Security" ;
    rdfs:comment "HIPAA transmission security requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:secureChannel ;
        minCount 1 ;
        severity sh:Violation ;
        message "Secure channel required" ;
    ] ;
    sh:property [
        sh:path yawl:authenticity ;
        minCount 1 ;
        severity sh:Warning ;
        message "Authenticity should be verified" ;
    ] ;
    sh:property [
        sh:path yawl:integrity ;
        minCount 1 ;
        severity sh:Warning ;
        message "Integrity should be verified" ;
    ] ;
    sh:property [
        sh:path yawl:nonRepudiation ;
        minCount 1 ;
        severity sh:Warning ;
        message "Non-repudiation should be provided" ;
    ] .

# Storage Security Shape
hipaa:StorageShape a sh:NodeShape ;
    rdfs:label "Storage Security" ;
    rdfs:comment "HIPAA storage security requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:accessControl ;
        minCount 1 ;
        severity sh:Violation ;
        message "Access control required" ;
    ] ;
    sh:property [
        sh:path yawl:auditControl ;
        minCount 1 ;
        severity sh:Warning ;
        message "Audit control should be implemented" ;
    ] ;
    sh:property [
        sh:path yawl:disposal ;
        minCount 1 ;
        severity sh:Violation ;
        message "Disposal procedures required" ;
    ] ;
    sh:property [
        sh:path yawl:backup ;
        minCount 1 ;
        severity sh:Warning ;
        message "Backup procedures should be implemented" ;
    ] .

# Accounting of Disclosures Shape
hipaa:AccountingShape a sh:NodeShape ;
    rdfs:label "Accounting of Disclosures" ;
    rdfs:comment "HIPAA accounting of disclosures requirements" ;
    sh:severity sh:Warning ;
    sh:property [
        sh:path yawl:accountingProcedure ;
        minCount 1 ;
        severity sh:Warning ;
        message "Accounting procedures should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:retentionPeriod ;
        minInclusive 6 ;
        severity sh:Warning ;
        message "Retention period should be at least 6 years" ;
    ] ;
    sh:property [
        sh:path yawl:accessProcedure ;
        minCount 1 ;
        severity sh:Warning ;
        message "Access procedures should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:feeStructure ;
        minCount 1 ;
        severity sh:Warning ;
        message "Fee structure should be defined" ;
    ] .

# Breach Notification Shape
hipaa:BreachNotificationShape a sh:NodeShape ;
    rdfs:label "Breach Notification" ;
    rdfs:comment "HIPAA breach notification requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:breachDetection ;
        minCount 1 ;
        severity sh:Violation ;
        message "Breach detection required" ;
    ] ;
    sh:property [
        sh:path yawl:notificationTime ;
        minInclusive 60 ;
        severity sh:Violation ;
        message "Notification within 60 days" ;
    ] ;
    sh:property [
        sh:path yawl:notificationContent ;
        minCount 1 ;
        severity sh:Violation ;
        message "Notification content required" ;
    ] ;
    sh:property [
        sh:path yawl:notificationMethod ;
        in ("written", "email", "electronic") ;
        severity sh:Warning ;
        message "Notification method should be appropriate" ;
    ] ;
    sh:property [
        sh:path yawl:lawEnforcement ;
        minCount 1 ;
        severity sh:Warning ;
        message "Law enforcement notification should be considered" ;
    ] .

# Business Associate Agreement Shape
hipaa:BusinessAssociateShape a sh:NodeShape ;
    rdfs:label "Business Associate" ;
    rdfs:comment "HIPAA business associate requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:hasBAA ;
        hasValue true ;
        severity sh:Violation ;
        message "Business Associate Agreement required" ;
    ] ;
    sh:property [
        sh:path yawl:baaScope ;
        minCount 1 ;
        severity sh:Warning ;
        message "BAA scope should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:baaDuration ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "BAA duration should be specified" ;
    ] ;
    sh:property [
        sh:path yawl:baaTermination ;
        minCount 1 ;
        severity sh:Warning ;
        message "BAA termination should be specified" ;
    ] ;
    sh:property [
        sh:path yawl:baaCompliance ;
        minCount 1 ;
        severity sh:Warning ;
        message "BAA compliance should be monitored" ;
    ] .