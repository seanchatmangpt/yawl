# SHACL Shapes for SOX Compliance (Sarbanes-Oxley Act)
# These shapes define YAWL workflow requirements for financial audit trails

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix yawl: <http://www.yawlfoundation.org/yawl#> .
@prefix sox: <http://www.yawlfoundation.org/sox#> .

# Base shapes
sox:ComplianceShape a sh:NodeShape ;
    rdfs:label "SOX Compliance Shape" ;
    rdfs:comment "Base shape for SOX compliance requirements" ;
    sh:severity sh:Violation ;
    sh:message "SOX compliance violation detected" ;
    sh:closed true ;
    sh:ignoredProperties (rdf:type) .

# Financial Process Shape
sox:FinancialProcessShape a sh:NodeShape ;
    rdfs:label "Financial Process" ;
    rdfs:comment "YAWL process that handles financial data" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Financial process must comply with SOX requirements" ;
    sh:property [
        sh:path yawl:hasTask ;
        sh:node sox:FinancialTaskShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial process must contain at least one financial task" ;
    ] ;
    sh:property [
        sh:path yawl:hasDocumentation ;
        minCount 1 ;
        severity sh:Warning ;
        message "Financial process should have documentation" ;
    ] ;
    sh:property [
        sh:path yawl:hasAuditTrail ;
        hasValue true ;
        severity sh:Violation ;
        message "Financial process must have audit trail" ;
    ] .

# Financial Task Shape
sox:FinancialTaskShape a sh:NodeShape ;
    rdfs:label "Financial Task" ;
    rdfs:comment "Task that handles financial data" ;
    sh:targetClass yawl:Task ;
    sh:severity sh:Violation ;
    sh:message "Financial task must comply with SOX requirements" ;
    sh:property [
        sh:path yawl:handlesFinancialData ;
        hasValue true ;
        severity sh:Violation ;
        message "Financial task must declare financial data handling" ;
    ] ;
    sh:property [
        sh:path yawl:hasAuditLog ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial task must maintain audit logs" ;
    ] ;
    sh:property [
        sh:path yawl:hasSegregationOfDuties ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial task must implement segregation of duties" ;
    ] ;
    sh:property [
        sh:path yawl:requiresAuthorization ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial task requires proper authorization" ;
    ] .

# Audit Trail Shape
sox:AuditTrailShape a sh:NodeShape ;
    rdfs:label "Audit Trail" ;
    rdfs:comment "Audit trail requirements for financial processes" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Financial process must maintain audit trails" ;
    sh:property [
        sh:path yawl:hasAuditTrail ;
        sh:node sox:AuditTrailDetailsShape ;
        severity sh:Violation ;
        message "Audit trail details required" ;
    ] .

# Audit Trail Details Shape
sox:AuditTrailDetailsShape a sh:NodeShape ;
    rdfs:label "Audit Trail Details" ;
    rdfs:comment "Detailed audit trail requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:auditTrailType ;
        hasValue "comprehensive" ;
        severity sh:Violation ;
        message "Comprehensive audit trail required" ;
    ] ;
    sh:property [
        sh:path yawl:retentionPeriod ;
        minInclusive 7 ;
        severity sh:Violation ;
        message "Audit trail retention must be at least 7 years" ;
    ] ;
    sh:property [
        sh:path yawl:immutableRecords ;
        hasValue true ;
        severity sh:Violation ;
        message "Audit trail records must be immutable" ;
    ] .

# Internal Controls Shape
sox:InternalControlsShape a sh:NodeShape ;
    rdfs:label "Internal Controls" ;
    rdfs:comment "Internal control requirements" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Financial process must have internal controls" ;
    sh:property [
        sh:path yawl:hasControl ;
        sh:node sox:ControlShape ;
        minCount 3 ;
        severity sh:Violation ;
        message "Financial process must have at least 3 internal controls" ;
    ] .

# Control Shape
sox:ControlShape a sh:NodeShape ;
    rdfs:label "Internal Control" ;
    rdfs:comment "Internal control definition" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:controlType ;
        in ("preventive", "detective", "corrective") ;
        severity sh:Violation ;
        message "Control must be preventive, detective, or corrective" ;
    ] ;
    sh:property [
        sh:path yawl:controlFrequency ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Control should have defined frequency" ;
    ] ;
    sh:property [
        sh:path yawl:controlOwner ;
        minCount 1 ;
        severity sh:Violation ;
        message "Control must have an owner" ;
    ] .

# Financial Data Integrity Shape
sox:DataIntegrityShape a sh:NodeShape ;
    rdfs:label "Financial Data Integrity" ;
    rdfs:comment "Financial data integrity requirements" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Financial data must maintain integrity" ;
    sh:property [
        sh:path yawl:hasDataValidation ;
        sh:node sox:DataValidationShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial data validation required" ;
    ] ;
    sh:property [
        sh:path yawl:hasDataBackup ;
        sh:node sox:DataBackupShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Financial data backup required" ;
    ] .

# Data Validation Shape
sox:DataValidationShape a sh:NodeShape ;
    rdfs:label "Data Validation" ;
    rdfs:comment "Data validation requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:validationType ;
        in ("format", "range", "business", "completeness") ;
        severity sh:Violation ;
        message "Validation must be format, range, business, or completeness" ;
    ] ;
    sh:property [
        sh:path yawl:validationFrequency ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Validation should have defined frequency" ;
    ] .

# Data Backup Shape
sox:DataBackupShape a sh:NodeShape ;
    rdfs:label "Data Backup" ;
    rdfs:comment "Data backup requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:backupFrequency ;
        minInclusive 1 ;
        severity sh:Violation ;
        message "Backup frequency must be defined" ;
    ] ;
    sh:property [
        sh:path yawl:backupRetention ;
        minInclusive 30 ;
        severity sh:Violation ;
        message "Backup retention must be at least 30 days" ;
    ] ;
    sh:property [
        sh:path yawl:backupEncryption ;
        hasValue true ;
        severity sh:Violation ;
        message "Backups must be encrypted" ;
    ] .

# Access Control Shape
sox:AccessControlShape a sh:NodeShape ;
    rdfs:label "Access Control" ;
    rdfs:comment "Access control requirements" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Violation ;
    sh:message "Financial process must enforce access controls" ;
    sh:property [
        sh:path yawl:hasAccessControl ;
        sh:node sox:AccessControlDetailShape ;
        minCount 1 ;
        severity sh:Violation ;
        message "Access control details required" ;
    ] .

# Access Control Detail Shape
sox:AccessControlDetailShape a sh:NodeShape ;
    rdfs:label "Access Control Details" ;
    rdfs:comment "Detailed access control requirements" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path yawl:accessLevel ;
        minCount 1 ;
        severity sh:Violation ;
        message "Access levels must be defined" ;
    ] ;
    sh:property [
        sh:path yawl:accessReview ;
        minInclusive 90 ;
        severity sh:Warning ;
        message "Access reviews should be at least 90 days" ;
    ] ;
    sh:property [
        sh:path yawl:accessRevocation ;
        hasValue true ;
        severity sh:Violation ;
        message "Access revocation procedures required" ;
    ] .

# Monitoring Shape
sox:MonitoringShape a sh:NodeShape ;
    rdfs:label "Monitoring" ;
    rdfs:comment "Monitoring requirements" ;
    sh:targetClass yawl:Specification ;
    sh:severity sh:Warning ;
    sh:message "Financial process should include monitoring" ;
    sh:property [
        sh:path yawl:hasMonitoring ;
        sh:node sox:MonitoringDetailShape ;
        severity sh:Warning ;
        message "Monitoring details should be defined" ;
    ] .

# Monitoring Detail Shape
sox:MonitoringDetailShape a sh:NodeShape ;
    rdfs:label "Monitoring Details" ;
    rdfs:comment "Detailed monitoring requirements" ;
    sh:severity sh:Warning ;
    sh:property [
        sh:path yawl:monitorType ;
        in ("realtime", "periodic", "eventdriven") ;
        severity sh:Warning ;
        message "Monitoring should be realtime, periodic, or eventdriven" ;
    ] ;
    sh:property [
        sh:path yawl:monitorFrequency ;
        minInclusive 1 ;
        severity sh:Warning ;
        message "Monitoring frequency should be defined" ;
    ] ;
    sh:property [
        sh:path yawl:alertThreshold ;
        minCount 1 ;
        severity sh:Warning ;
        message "Alert thresholds should be defined" ;
    ] .