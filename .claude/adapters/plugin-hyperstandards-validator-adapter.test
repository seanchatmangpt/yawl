#!/usr/bin/env bash
# HyperStandardsValidator Adapter Test Suite
#
# Tests the plugin adapter against various scenarios:
# - Happy path: No violations
# - Error path: Multiple violations detected
# - Edge cases: Empty directory, missing files
#
# Run with: bash plugin-hyperstandards-validator-adapter.test
#
# Exit codes:
#   0 = All tests passed
#   1 = One or more tests failed

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# TEST SETUP
# ──────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADAPTER_SCRIPT="${SCRIPT_DIR}/plugin-hyperstandards-validator-adapter.sh"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
TEST_DIR="/tmp/hyperstandards-adapter-test-$$"
TEST_RECEIPTS_DIR="${TEST_DIR}/.claude/receipts"

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Test counters
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0

# ──────────────────────────────────────────────────────────────────────────────
# TEST HELPERS
# ──────────────────────────────────────────────────────────────────────────────

setup_test_env() {
    mkdir -p "${TEST_DIR}/.claude/receipts"
    mkdir -p "${TEST_DIR}/emit"
}

cleanup_test_env() {
    rm -rf "${TEST_DIR}"
}

test_start() {
    local test_name="$1"
    echo -e "\n${YELLOW}[TEST]${NC} Starting: ${test_name}"
    ((TESTS_RUN++))
}

test_pass() {
    local test_name="$1"
    echo -e "${GREEN}[PASS]${NC} ${test_name}"
    ((TESTS_PASSED++))
}

test_fail() {
    local test_name="$1"
    local reason="$2"
    echo -e "${RED}[FAIL]${NC} ${test_name}: ${reason}"
    ((TESTS_FAILED++))
}

assert_file_exists() {
    local file="$1"
    if [[ -f "${file}" ]]; then
        return 0
    else
        return 1
    fi
}

assert_json_valid() {
    local json_file="$1"
    if jq empty "${json_file}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

assert_json_field_equals() {
    local json_file="$1"
    local field="$2"
    local expected="$3"
    local actual=$(jq -r ".${field}" "${json_file}")
    if [[ "${actual}" == "${expected}" ]]; then
        return 0
    else
        echo "    Expected: ${expected}, Got: ${actual}"
        return 1
    fi
}

assert_json_field_exists() {
    local json_file="$1"
    local field="$2"
    if jq -e ".${field}" "${json_file}" >/dev/null 2>&1; then
        return 0
    else
        echo "    Field ${field} not found in JSON"
        return 1
    fi
}

# ──────────────────────────────────────────────────────────────────────────────
# TESTS
# ──────────────────────────────────────────────────────────────────────────────

# Test 1: Adapter script exists and is executable
test_adapter_exists() {
    test_start "Adapter script exists"

    if assert_file_exists "${ADAPTER_SCRIPT}"; then
        test_pass "Adapter script exists"
    else
        test_fail "Adapter script exists" "File not found: ${ADAPTER_SCRIPT}"
        return 1
    fi

    if [[ -x "${ADAPTER_SCRIPT}" ]]; then
        test_pass "Adapter script is executable"
    else
        test_fail "Adapter script is executable" "Script is not executable"
        return 1
    fi
}

# Test 2: Adapter handles missing emit directory gracefully
test_missing_emit_dir() {
    test_start "Adapter handles missing emit directory"

    local result_dir="${TEST_DIR}-missing-emit"
    mkdir -p "${result_dir}/.claude/receipts"

    if EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null; then
        if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
            test_pass "Adapter creates receipt even without emit dir"
        else
            test_fail "Adapter creates receipt" "Receipt file not created"
        fi
    else
        # This is OK - adapter can exit 0 or gracefully handle missing dir
        test_pass "Adapter handles missing emit directory"
    fi

    rm -rf "${result_dir}"
}

# Test 3: Receipt JSON structure validation
test_receipt_json_structure() {
    test_start "Receipt JSON has correct structure"

    local result_dir="${TEST_DIR}-json-structure"
    mkdir -p "${result_dir}/.claude/receipts"
    mkdir -p "${result_dir}/emit"

    # Create minimal Java file
    cat > "${result_dir}/emit/Test.java" <<'JAVA'
public class Test {
    // TODO: implement this
}
JAVA

    # Run adapter (it may fail due to missing Maven, but receipt should be created)
    EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null || true

    if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
        if assert_json_valid "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
            test_pass "Receipt JSON is valid"
        else
            test_fail "Receipt JSON is valid" "JSON parsing failed"
        fi

        # Check required fields
        for field in "phase" "timestamp" "plugin" "status" "exit_code"; do
            if assert_json_field_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json" "${field}"; then
                echo "      ✓ Field '${field}' present"
            else
                test_fail "Receipt JSON fields" "Missing required field: ${field}"
            fi
        done
    else
        test_fail "Receipt file created" "File not found"
    fi

    rm -rf "${result_dir}"
}

# Test 4: Receipt contains violations array
test_receipt_violations_array() {
    test_start "Receipt contains violations array"

    local result_dir="${TEST_DIR}-violations-array"
    mkdir -p "${result_dir}/.claude/receipts"
    mkdir -p "${result_dir}/emit"

    # Create Java file with violations
    cat > "${result_dir}/emit/BadCode.java" <<'JAVA'
public class BadCode {
    // TODO: implement this
    public void mockMethod() { return; }
}
JAVA

    EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null || true

    if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
        if assert_json_field_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json" "violations"; then
            test_pass "Receipt contains violations array"
        else
            test_fail "Violations array" "Not found in receipt"
        fi

        # Check violations_count field
        if assert_json_field_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json" "violations_count"; then
            test_pass "Receipt contains violations_count"
        else
            test_fail "violations_count" "Not found in receipt"
        fi
    fi

    rm -rf "${result_dir}"
}

# Test 5: Receipt status is GREEN when no violations
test_receipt_status_green() {
    test_start "Receipt status is GREEN when no violations"

    local result_dir="${TEST_DIR}-status-green"
    mkdir -p "${result_dir}/.claude/receipts"
    mkdir -p "${result_dir}/emit"

    # Create clean Java file
    cat > "${result_dir}/emit/GoodCode.java" <<'JAVA'
public class GoodCode {
    public void doWork() {
        throw new UnsupportedOperationException(
            "Implementation required. See REQUIREMENTS.md"
        );
    }
}
JAVA

    EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null || true

    if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
        if assert_json_field_equals "${result_dir}/.claude/receipts/hyperstandards-receipt.json" "status" "GREEN"; then
            test_pass "Status is GREEN for clean code"
        else
            test_fail "Status field" "Expected GREEN, check file content"
        fi
    fi

    rm -rf "${result_dir}"
}

# Test 6: Exit code matches status
test_exit_code_matches_status() {
    test_start "Exit code in receipt matches status"

    local result_dir="${TEST_DIR}-exit-code"
    mkdir -p "${result_dir}/.claude/receipts"
    mkdir -p "${result_dir}/emit"

    # Create minimal file
    touch "${result_dir}/emit/Test.java"

    EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null || true

    if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
        local status=$(jq -r '.status' "${result_dir}/.claude/receipts/hyperstandards-receipt.json")
        local exit_code=$(jq -r '.exit_code' "${result_dir}/.claude/receipts/hyperstandards-receipt.json")

        if [[ "${status}" == "GREEN" && ${exit_code} -eq 0 ]] || \
           [[ "${status}" == "RED" && ${exit_code} -eq 2 ]]; then
            test_pass "Exit code matches status (GREEN=0, RED=2)"
        else
            test_fail "Exit code" "Status=${status}, Code=${exit_code} mismatch"
        fi
    fi

    rm -rf "${result_dir}"
}

# Test 7: Receipt contains recommendations
test_receipt_recommendations() {
    test_start "Receipt contains remediation recommendations"

    local result_dir="${TEST_DIR}-recommendations"
    mkdir -p "${result_dir}/.claude/receipts"
    mkdir -p "${result_dir}/emit"

    touch "${result_dir}/emit/Test.java"

    EMIT_DIR="${result_dir}/emit" bash "${ADAPTER_SCRIPT}" 2>/dev/null || true

    if assert_file_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json"; then
        if assert_json_field_exists "${result_dir}/.claude/receipts/hyperstandards-receipt.json" "recommendations"; then
            test_pass "Receipt contains recommendations"
        else
            test_fail "Recommendations" "Not found in receipt"
        fi
    fi

    rm -rf "${result_dir}"
}

# ──────────────────────────────────────────────────────────────────────────────
# TEST RUNNER
# ──────────────────────────────────────────────────────────────────────────────

run_all_tests() {
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  HyperStandardsValidator Adapter Test Suite                  ║"
    echo "╚══════════════════════════════════════════════════════════════╝"

    setup_test_env

    # Run tests
    test_adapter_exists || true
    test_missing_emit_dir || true
    test_receipt_json_structure || true
    test_receipt_violations_array || true
    test_receipt_status_green || true
    test_exit_code_matches_status || true
    test_receipt_recommendations || true

    cleanup_test_env

    # Summary
    echo -e "\n╔══════════════════════════════════════════════════════════════╗"
    echo -e "║  Test Summary                                                ║"
    echo -e "╚══════════════════════════════════════════════════════════════╝"
    echo "  Total tests run:    ${TESTS_RUN}"
    echo -e "  ${GREEN}Passed${NC}:              ${TESTS_PASSED}"
    echo -e "  ${RED}Failed${NC}:              ${TESTS_FAILED}"
    echo ""

    if [[ ${TESTS_FAILED} -eq 0 ]]; then
        echo -e "${GREEN}✓ All tests passed!${NC}"
        return 0
    else
        echo -e "${RED}✗ Some tests failed. Please review.${NC}"
        return 1
    fi
}

# Main execution
run_all_tests
exit $?
