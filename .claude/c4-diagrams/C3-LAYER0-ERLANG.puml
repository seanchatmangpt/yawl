@startuml C3_Layer0_Erlang
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title YAWL Layer 0 - yawl-erlang Distributed Messaging

Container_Boundary(erlang_layer, "yawl-erlang") {

    Component_Boundary(erlang_node, "Erlang Node Management") {
        Component(node_setup, "NodeSetup", "Initialization", "OTP 28 setup")
        Component(node_discovery, "NodeDiscovery", "Cluster", "Node registration")
        Component(node_health, "NodeHealthMonitor", "Heartbeat", "Node liveness")
        Component(node_shutdown, "GracefulShutdown", "Cleanup", "Orderly termination")
    }

    Component_Boundary(distributed_rpc, "Distributed RPC") {
        Component(rpc_client, "RPCClient", "Call initiator", "Remote function calls")
        Component(rpc_server, "RPCServer", "Call receiver", "Function invocation")
        Component(rpc_router, "RPCRouter", "Routing", "Node selection")
        Component(rpc_cache, "RPCCache", "Results", "Response caching")
    }

    Component_Boundary(message_passing, "Message Passing") {
        Component(msg_queue, "MessageQueue", "Erlang queue", "Async messages")
        Component(msg_serializer, "MessageSerializer", "Erlang binary", "Serialization")
        Component(msg_delivery, "MessageDelivery", "Guaranteed", "Delivery guarantee")
        Component(msg_ordering, "MessageOrdering", "FIFO", "Order preservation")
    }

    Component_Boundary(distributed_cache, "Distributed Cache") {
        Component(mnesia_wrapper, "MnesiaWrapper", "In-memory DB", "Replicated cache")
        Component(cache_sync, "CacheSync", "Replication", "Multi-node sync")
        Component(cache_invalidation, "InvalidationManager", "Broadcast", "Cache updates")
    }

    Component_Boundary(failover, "Failover & HA") {
        Component(supervisor, "Supervisor", "Process tree", "Restart strategy")
        Component(failover_mgr, "FailoverManager", "Active-passive", "Node failover")
        Component(replica_mgr, "ReplicaManager", "Multi-master", "Replica sync")
    }

    Component_Boundary(monitoring_erlang, "Monitoring") {
        Component(process_monitor, "ProcessMonitor", "Erlang processes", "Process tracking")
        Component(link_monitor, "LinkMonitor", "Links", "Process links")
        Component(trap_exit, "TrapExit", "Error handling", "Exception propagation")
    }

}

Rel(node_setup, node_discovery, "Registers node", "")
Rel(node_discovery, node_health, "Monitored by", "")
Rel(rpc_client, rpc_router, "Uses for routing", "")
Rel(rpc_router, rpc_server, "Routes to", "")
Rel(rpc_server, rpc_cache, "Caches results", "")

Rel(msg_queue, msg_serializer, "Serializes for", "")
Rel(msg_serializer, msg_delivery, "Delivers", "")
Rel(msg_delivery, msg_ordering, "Guarantees", "")

Rel(mnesia_wrapper, cache_sync, "Syncs with", "")
Rel(cache_invalidation, mnesia_wrapper, "Invalidates", "")

Rel(supervisor, failover_mgr, "Manages", "")
Rel(failover_mgr, replica_mgr, "Coordinates", "")

Rel(process_monitor, link_monitor, "Tracks", "")
Rel(link_monitor, trap_exit, "Routes exits", "")

SHOW_LEGEND()
@enduml
